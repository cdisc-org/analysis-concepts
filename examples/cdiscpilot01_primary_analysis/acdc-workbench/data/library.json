  "templates": {
    "dc": [
      {
        "id": "T_DC_Baseline",
        "name": "BaselineDerivation",
        "type": "derivation",
        "version": "1.0.0",
        "clinical_intent": "Derive baseline value from the baseline visit observation",
        "uses_method": "Aggregation",
        "methods": [],
        "role_bindings": [
          {
            "semantic_transformation_concept": "observation_value",
            "method_role": "value",
            "direction": "input",
            "cube_role": "measure",
            "data_type": "numeric"
          },
          {
            "semantic_transformation_concept": "subject",
            "method_role": "partition",
            "direction": "input",
            "cube_role": "dimension",
            "data_type": "string"
          },
          {
            "semantic_transformation_concept": "parameter",
            "method_role": "partition",
            "direction": "input",
            "cube_role": "dimension",
            "data_type": "string"
          },
          {
            "semantic_transformation_concept": "baseline_flag",
            "method_role": "filter",
            "direction": "input",
            "cube_role": "filter",
            "data_type": "boolean",
            "description": "Filter to baseline records only"
          },
          {
            "semantic_transformation_concept": "baseline_value",
            "method_role": "result",
            "direction": "output",
            "cube_role": "measure",
            "data_type": "numeric"
          }
        ],
        "parameters": {
          "agg_func": "FIRST",
          "order_by": "visit_numeric"
        },
        "del_expression": "baseline_value := FIRST(observation_value) OVER (subject, parameter) WHERE baseline_flag = TRUE ORDER BY visit_numeric"
      },
      {
        "id": "T_DC_EfficacyFlag",
        "name": "EfficacyPopulationFlag",
        "type": "derivation",
        "version": "1.0.0",
        "clinical_intent": "Derive efficacy population membership flag based on study criteria",
        "uses_method": "LogicalCombination",
        "methods": [],
        "role_bindings": [
          {
            "semantic_transformation_concept": "population_flag",
            "method_role": "conditions",
            "direction": "input",
            "cube_role": "filter",
            "data_type": "boolean",
            "description": "Safety population flag (SAFFL='Y')"
          },
          {
            "semantic_transformation_concept": "baseline_value",
            "method_role": "conditions",
            "direction": "input",
            "cube_role": "measure",
            "data_type": "numeric",
            "description": "Has baseline ADAS-Cog assessment (not missing)"
          },
          {
            "semantic_transformation_concept": "analysis_value",
            "method_role": "conditions",
            "direction": "input",
            "cube_role": "measure",
            "data_type": "numeric",
            "description": "Has at least one post-baseline ADAS-Cog assessment (not missing)"
          },
          {
            "semantic_transformation_concept": "efficacy_flag",
            "method_role": "result",
            "direction": "output",
            "cube_role": "filter",
            "data_type": "boolean"
          }
        ],
        "parameters": {
          "logic_op": "AND"
        },
        "del_expression": "efficacy_flag := safety_flag AND NOT MISSING(baseline_value) AND EXISTS(post_baseline_assessment)"
      },
      {
        "id": "T_DC_LOCF",
        "name": "LOCFImputation",
        "type": "derivation",
        "version": "1.0.0",
        "clinical_intent": "Last Observation Carried Forward imputation for missing values",
        "uses_method": "WindowLookup",
        "methods": [],
        "role_bindings": [
          {
            "semantic_transformation_concept": "analysis_value",
            "method_role": "value",
            "direction": "input",
            "cube_role": "measure",
            "data_type": "numeric"
          },
          {
            "semantic_transformation_concept": "subject",
            "method_role": "partition",
            "direction": "input",
            "cube_role": "dimension",
            "data_type": "string"
          },
          {
            "semantic_transformation_concept": "parameter",
            "method_role": "partition",
            "direction": "input",
            "cube_role": "dimension",
            "data_type": "string"
          },
          {
            "semantic_transformation_concept": "visit",
            "method_role": "order_var",
            "direction": "input",
            "cube_role": "dimension",
            "data_type": "string"
          },
          {
            "semantic_transformation_concept": "analysis_value",
            "method_role": "result",
            "direction": "output",
            "cube_role": "measure",
            "data_type": "numeric",
            "description": "Imputed analysis value (LOCF applied)"
          }
        ],
        "parameters": {
          "window_func": "LAST_VALUE",
          "ignore_nulls": true
        },
        "del_expression": "imputed_value := LAST_VALUE(analysis_value IGNORE NULLS) OVER (subject, parameter) ORDER BY visit_numeric ROWS UNBOUNDED PRECEDING"
      },
      {
        "id": "T_DC_ChangeFromBaseline",
        "name": "ChangeFromBaseline",
        "type": "derivation",
        "version": "1.0.0",
        "clinical_intent": "Calculate the absolute change from baseline value",
        "uses_method": "Subtraction",
        "methods": [],
        "role_bindings": [
          {
            "semantic_transformation_concept": "analysis_value",
            "method_role": "minuend",
            "direction": "input",
            "cube_role": "measure"
          },
          {
            "semantic_transformation_concept": "baseline_value",
            "method_role": "subtrahend",
            "direction": "input",
            "cube_role": "measure"
          },
          {
            "semantic_transformation_concept": "change_value",
            "method_role": "difference",
            "direction": "output",
            "cube_role": "measure"
          }
        ],
        "parameters": {},
        "del_expression": "change_value := analysis_value - baseline_value",
        "input_cube": {
          "name": "input_cube",
          "dimensions": [
            {
              "data_concept": "subject",
              "role": "dimension"
            },
            {
              "data_concept": "parameter",
              "role": "dimension"
            },
            {
              "data_concept": "visit",
              "role": "dimension"
            }
          ],
          "measures": [
            {
              "data_concept": "analysis_value",
              "role": "value"
            },
            {
              "data_concept": "baseline_value",
              "role": "value"
            }
          ]
        },
        "output_cube": {
          "name": "output_cube",
          "dimensions": [
            {
              "data_concept": "subject",
              "role": "dimension"
            },
            {
              "data_concept": "parameter",
              "role": "dimension"
            },
            {
              "data_concept": "visit",
              "role": "dimension"
            }
          ],
          "measures": [
            {
              "data_concept": "change_value",
              "role": "result"
            }
          ]
        },
        "slice": {
          "name": "parameter_filter",
          "constraints": [
            {
              "data_concept": "parameter"
            }
          ]
        }
      }
    ],
    "ac": [
      {
        "id": "T_AC_ANCOVA_DoseResponse",
        "name": "CFB_ANCOVA_DoseResponse",
        "type": "analysis",
        "version": "1.0.0",
        "clinical_intent": "Test dose-response relationship for change from baseline using treatment dose as continuous predictor, adjusting for baseline value and site",
        "uses_method": "ancova_dose_response",
        "methods": [],
        "role_bindings": [
          {
            "semantic_transformation_concept": "change_value",
            "method_role": "response",
            "direction": "input",
            "cube_role": "measure",
            "phrase_ref": "SP_CFB_ENDPOINT"
          },
          {
            "semantic_transformation_concept": "baseline_value",
            "method_role": "covariate",
            "direction": "input",
            "cube_role": "measure"
          },
          {
            "semantic_transformation_concept": "site",
            "method_role": "factor",
            "direction": "input",
            "cube_role": "dimension"
          },
          {
            "semantic_transformation_concept": "treatment_dose",
            "method_role": "continuous_predictor",
            "direction": "input",
            "cube_role": "measure"
          },
          {
            "semantic_transformation_concept": "slope",
            "method_role": "slope",
            "direction": "output",
            "cube_role": "measure"
          },
          {
            "semantic_transformation_concept": "slope_se",
            "method_role": "slope_se",
            "direction": "output",
            "cube_role": "measure"
          },
          {
            "semantic_transformation_concept": "p_value",
            "method_role": "p_value",
            "direction": "output",
            "cube_role": "measure"
          },
