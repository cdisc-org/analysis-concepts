{
  "version": "1.0.0",
  "description": "AC/DC Standards Library",
  "methods": {
    "derivation": [
      {
        "name": "Subtraction",
        "type": "derivation",
        "description": "Difference between two values",
        "del_expression": "difference := minuend - subtrahend",
        "roles": [
          {
            "name": "minuend",
            "direction": "input",
            "data_type": "numeric",
            "description": "Value to subtract from"
          },
          {
            "name": "subtrahend",
            "direction": "input",
            "data_type": "numeric",
            "description": "Value to subtract"
          },
          {
            "name": "difference",
            "direction": "output",
            "data_type": "numeric",
            "description": "Result of subtraction"
          }
        ],
        "parameters": []
      },
      {
        "name": "Aggregation",
        "type": "derivation",
        "description": "Aggregate over partition to derive a single value",
        "del_expression": "result := AGG(value) OVER partition WHERE condition",
        "roles": [
          {
            "name": "value",
            "direction": "input",
            "data_type": "any",
            "description": "Value to aggregate"
          },
          {
            "name": "partition",
            "direction": "input",
            "data_type": "any",
            "description": "Grouping variables for aggregation"
          },
          {
            "name": "result",
            "direction": "output",
            "data_type": "any",
            "description": "Aggregated result"
          }
        ],
        "parameters": [
          {
            "name": "agg_func",
            "type": "enum",
            "default": "FIRST",
            "values": [
              "FIRST",
              "LAST",
              "MIN",
              "MAX",
              "SUM",
              "AVG",
              "COUNT"
            ],
            "description": "Aggregation function to apply"
          },
          {
            "name": "order_by",
            "type": "string",
            "description": "Variable(s) to order by before aggregation"
          }
        ]
      },
      {
        "name": "WindowLookup",
        "type": "derivation",
        "description": "Value from another row within window (for LOCF, BOCF)",
        "del_expression": "result := WINDOW(value, offset) OVER partition ORDER BY order_var",
        "roles": [
          {
            "name": "value",
            "direction": "input",
            "data_type": "any",
            "description": "Value to look up"
          },
          {
            "name": "partition",
            "direction": "input",
            "data_type": "any",
            "description": "Grouping variables for window"
          },
          {
            "name": "order_var",
            "direction": "input",
            "data_type": "any",
            "description": "Variable(s) defining row order"
          },
          {
            "name": "result",
            "direction": "output",
            "data_type": "any",
            "description": "Looked-up value"
          }
        ],
        "parameters": [
          {
            "name": "window_func",
            "type": "enum",
            "default": "LAG",
            "values": [
              "LAG",
              "LEAD",
              "FIRST_VALUE",
              "LAST_VALUE"
            ],
            "description": "Window function to apply"
          },
          {
            "name": "offset",
            "type": "numeric",
            "default": 1,
            "description": "Number of rows to look back/forward"
          },
          {
            "name": "ignore_nulls",
            "type": "boolean",
            "default": true,
            "description": "Skip null values when looking up"
          }
        ]
      },
      {
        "name": "Imputation",
        "type": "derivation",
        "description": "Replace missing values with imputed values",
        "del_expression": "result := COALESCE(value, imputed_value)",
        "roles": [
          {
            "name": "value",
            "direction": "input",
            "data_type": "any",
            "description": "Original value (may be missing)"
          },
          {
            "name": "imputed_value",
            "direction": "input",
            "data_type": "any",
            "description": "Value to use if original is missing"
          },
          {
            "name": "result",
            "direction": "output",
            "data_type": "any",
            "description": "Coalesced result"
          }
        ],
        "parameters": []
      },
      {
        "name": "ThresholdCompare",
        "type": "derivation",
        "description": "Compare value to threshold and return flag",
        "del_expression": "result := IF(value >= threshold, true_val, false_val)",
        "roles": [
          {
            "name": "value",
            "direction": "input",
            "data_type": "any",
            "description": "Value to compare"
          },
          {
            "name": "threshold",
            "direction": "input",
            "data_type": "any",
            "description": "Threshold for comparison"
          },
          {
            "name": "result",
            "direction": "output",
            "data_type": "any",
            "description": "Result of comparison"
          }
        ],
        "parameters": [
          {
            "name": "operator",
            "type": "enum",
            "default": ">=",
            "values": [
              "=",
              "!=",
              "<",
              "<=",
              ">",
              ">="
            ],
            "description": "Comparison operator"
          },
          {
            "name": "true_val",
            "type": "any",
            "default": "Y",
            "description": "Value when condition is true"
          },
          {
            "name": "false_val",
            "type": "any",
            "default": "N",
            "description": "Value when condition is false"
          }
        ]
      },
      {
        "name": "LogicalCombination",
        "type": "derivation",
        "description": "Combine multiple boolean conditions",
        "del_expression": "result := condition1 AND condition2 AND ... conditionN",
        "roles": [
          {
            "name": "conditions",
            "direction": "input",
            "data_type": "boolean",
            "description": "Boolean conditions to combine (multiple inputs)"
          },
          {
            "name": "result",
            "direction": "output",
            "data_type": "boolean",
            "description": "Combined result"
          }
        ],
        "parameters": [
          {
            "name": "logic_op",
            "type": "enum",
            "default": "AND",
            "values": [
              "AND",
              "OR"
            ],
            "description": "Logical operator to combine conditions"
          }
        ]
      }
    ],
    "analysis": [
      {
        "name": "ancova",
        "type": "analysis",
        "description": "Analysis of covariance - compares group means controlling for continuous covariates",
        "del_expression": "response ~ covariate + group",
        "roles": [
          {
            "name": "response",
            "direction": "input",
            "data_type": "numeric",
            "description": "Dependent variable (outcome)"
          },
          {
            "name": "covariate",
            "direction": "input",
            "data_type": "numeric",
            "description": "Continuous covariate for adjustment"
          },
          {
            "name": "group",
            "direction": "input",
            "data_type": "string",
            "description": "Categorical grouping factor"
          },
          {
            "name": "ls_means",
            "direction": "output",
            "data_type": "numeric",
            "description": "Least-squares means per group"
          },
          {
            "name": "ls_mean_difference",
            "direction": "output",
            "data_type": "numeric",
            "description": "Difference in LS means"
          },
          {
            "name": "confidence_interval_upper",
            "direction": "output",
            "data_type": "numeric",
            "description": "Upper CI for LS mean difference"
          },
          {
            "name": "p_value",
            "direction": "output",
            "data_type": "numeric",
            "description": "P-value for treatment effect"
          },
          {
            "name": "f_statistic",
            "direction": "output",
            "data_type": "numeric",
            "description": "F-statistic for each effect"
          },
          {
            "name": "confidence_interval_lower",
            "direction": "output",
            "data_type": "numeric",
            "description": "Lower CI for LS mean difference"
          }
        ],
        "parameters": [
          {
            "name": "ss_type",
            "type": "enum",
            "default": "III",
            "description": "Type of sum of squares"
          },
          {
            "name": "alpha",
            "type": "numeric",
            "default": "0.05",
            "description": "Significance level"
          },
          {
            "name": "interaction",
            "type": "boolean",
            "description": "Include covariate x group interaction"
          }
        ]
      },
      {
        "name": "ancova_dose_response",
        "type": "analysis",
        "description": "ANCOVA with treatment as continuous variable for dose-response trend testing",
        "del_expression": "response ~ covariate + factor + continuous_predictor",
        "roles": [
          {
            "name": "response",
            "direction": "input",
            "data_type": "numeric",
            "description": "Dependent variable (change from baseline)"
          },
          {
            "name": "covariate",
            "direction": "input",
            "data_type": "numeric",
            "description": "Baseline value as covariate"
          },
          {
            "name": "factor",
            "direction": "input",
            "data_type": "string",
            "description": "Categorical factor (e.g., site)"
          },
          {
            "name": "continuous_predictor",
            "direction": "input",
            "data_type": "numeric",
            "description": "Treatment dose as continuous predictor"
          },
          {
            "name": "slope",
            "direction": "output",
            "data_type": "numeric",
            "description": "Slope estimate for dose-response"
          },
          {
            "name": "slope_se",
            "direction": "output",
            "data_type": "numeric",
            "description": "Standard error of slope"
          },
          {
            "name": "p_value",
            "direction": "output",
            "data_type": "numeric",
            "description": "P-value for dose-response trend"
          },
          {
            "name": "confidence_interval_upper",
            "direction": "output",
            "data_type": "numeric",
            "description": "Upper CI for slope estimate"
          },
          {
            "name": "f_statistic",
            "direction": "output",
            "data_type": "numeric",
            "description": "F-statistic for dose-response effect"
          },
          {
            "name": "confidence_interval_lower",
            "direction": "output",
            "data_type": "numeric",
            "description": "Lower CI for slope estimate"
          }
        ],
        "parameters": [
          {
            "name": "ss_type",
            "type": "enum",
            "default": "III",
            "description": "Type of sum of squares"
          },
          {
            "name": "alpha",
            "type": "numeric",
            "default": "0.05",
            "description": "Significance level"
          }
        ]
      }
    ]
  },
