{
  "$schema": "https://cdisc.org/ac-dc/v1/template-schema.json",
  "template": {
    "id": "T_AC_ANCOVA_DoseResponse",
    "name": "CFB_ANCOVA_DoseResponse",
    "type": "analysis",
    "version": "1.0.0",
    "clinical_intent": "Test dose-response relationship for change from baseline using treatment dose as continuous predictor, adjusting for baseline value and site",
    "uses_method": "ancova_dose_response",
    "parameters": {
      "ss_type": "III",
      "alpha": 0.05
    },
    "role_bindings": [
      {
        "semantic_transformation_concept": "change_value",
        "method_role": "response",
        "direction": "input",
        "cube_role": "measure",
        "data_type": "numeric",
        "description": "Change from baseline as the dependent variable"
      },
      {
        "semantic_transformation_concept": "baseline_value",
        "method_role": "covariate",
        "direction": "input",
        "cube_role": "measure",
        "data_type": "numeric",
        "description": "Baseline value as continuous covariate"
      },
      {
        "semantic_transformation_concept": "site",
        "method_role": "factor",
        "direction": "input",
        "cube_role": "dimension",
        "data_type": "string",
        "description": "Site as categorical fixed effect"
      },
      {
        "semantic_transformation_concept": "treatment_dose",
        "method_role": "continuous_predictor",
        "direction": "input",
        "cube_role": "measure",
        "data_type": "numeric",
        "description": "Treatment dose as continuous predictor for dose-response trend"
      },
      {
        "semantic_transformation_concept": "population_flag",
        "method_role": "filter",
        "direction": "input",
        "cube_role": "filter",
        "data_type": "boolean",
        "description": "Population membership flag for subsetting"
      },
      {
        "semantic_transformation_concept": "slope",
        "method_role": "slope",
        "direction": "output",
        "cube_role": "measure",
        "data_type": "numeric",
        "description": "Slope estimate for dose-response relationship"
      },
      {
        "semantic_transformation_concept": "slope_se",
        "method_role": "slope_se",
        "direction": "output",
        "cube_role": "measure",
        "data_type": "numeric",
        "description": "Standard error of slope estimate"
      },
      {
        "semantic_transformation_concept": "p_value",
        "method_role": "p_value",
        "direction": "output",
        "cube_role": "measure",
        "data_type": "numeric",
        "description": "P-value for dose-response trend test"
      },
      {
        "semantic_transformation_concept": "confidence_interval_lower",
        "method_role": "confidence_interval",
        "direction": "output",
        "cube_role": "measure",
        "data_type": "numeric",
        "description": "Lower bound of 95% CI for slope"
      },
      {
        "semantic_transformation_concept": "confidence_interval_upper",
        "method_role": "confidence_interval",
        "direction": "output",
        "cube_role": "measure",
        "data_type": "numeric",
        "description": "Upper bound of 95% CI for slope"
      }
    ],
    "del_expression": "response ~ covariate + factor + continuous_predictor",
    "model_specification": {
      "family": "Gaussian",
      "link": "Identity",
      "estimation": "OLS",
      "hypothesis_test": {
        "type": "dose_response_trend",
        "null": "slope = 0",
        "alternative": "slope != 0"
      }
    },
    "required_phrases": [
      {
        "role": "endpoint",
        "must_reference": "change_value"
      },
      {
        "role": "covariate",
        "must_reference": "baseline_value"
      },
      {
        "role": "grouping",
        "must_reference": ["site", "treatment_dose"]
      },
      {
        "role": "population",
        "must_reference": "population_flag"
      },
      {
        "role": "method",
        "must_be": "ancova_dose_response"
      }
    ]
  }
}
