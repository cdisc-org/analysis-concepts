{
  "$schema": "https://cdisc.org/ac-dc/v1/template-schema.json",
  "template": {
    "id": "T_DC_LOCF",
    "name": "LOCFImputation",
    "type": "derivation",
    "version": "1.0.0",
    "clinical_intent": "Last Observation Carried Forward imputation for missing values",
    "uses_method": "WindowLookup",
    "parameters": {
      "window_func": "LAST_VALUE",
      "ignore_nulls": true
    },
    "role_bindings": [
      {
        "semantic_transformation_concept": "analysis_value",
        "method_role": "value",
        "direction": "input",
        "cube_role": "measure",
        "data_type": "numeric"
      },
      {
        "semantic_transformation_concept": "subject",
        "method_role": "partition",
        "direction": "input",
        "cube_role": "dimension",
        "data_type": "string"
      },
      {
        "semantic_transformation_concept": "parameter",
        "method_role": "partition",
        "direction": "input",
        "cube_role": "dimension",
        "data_type": "string"
      },
      {
        "semantic_transformation_concept": "visit",
        "method_role": "order_var",
        "direction": "input",
        "cube_role": "dimension",
        "data_type": "string"
      },
      {
        "semantic_transformation_concept": "analysis_value",
        "method_role": "result",
        "direction": "output",
        "cube_role": "measure",
        "data_type": "numeric",
        "description": "Imputed analysis value (LOCF applied)"
      }
    ],
    "del_expression": "imputed_value := LAST_VALUE(analysis_value IGNORE NULLS) OVER (subject, parameter) ORDER BY visit_numeric ROWS UNBOUNDED PRECEDING",
    "output_qualifier": {
      "semantic_transformation_concept": "derivation_type",
      "value": "LOCF",
      "condition": "When original analysis_value is missing"
    }
  }
}
