{
  "$schema": "https://cdisc.org/ac-dc/v1/instance-schema.json",
  "instance": {
    "id": "S_DC_ADAS_LOCF",
    "name": "ADAS-Cog(11) LOCF Imputation at Week 24",
    "type": "derivation_instance",
    "version": "1.0.0",
    "instance_of": "T_DC_LOCF",
    "study": "CDISCPILOT01",
    "description": "Apply LOCF imputation for missing ADAS-Cog(11) values at Week 24",
    "depends_on": ["S_DC_ADAS_Change"],

    "method": {
      "name": "WindowLookup",
      "formula": "imputed_value = LAST_VALUE(analysis_value IGNORE NULLS) OVER (PARTITION BY subject, parameter ORDER BY visit_numeric ROWS UNBOUNDED PRECEDING)"
    },

    "input_cube": {
      "name": "locf_input",
      "dimensions": [
        {"data_concept": "subject", "role": "identifier"},
        {"data_concept": "visit", "role": "identifier"},
        {"data_concept": "visit_numeric", "role": "identifier"},
        {"data_concept": "parameter", "role": "identifier"}
      ],
      "measures": [
        {"data_concept": "analysis_value", "role": "value"},
        {"data_concept": "change_value", "role": "value"}
      ]
    },

    "output_cube": {
      "name": "locf_output",
      "dimensions": [
        {"data_concept": "subject", "role": "identifier"},
        {"data_concept": "visit", "role": "identifier"},
        {"data_concept": "visit_numeric", "role": "identifier"},
        {"data_concept": "parameter", "role": "identifier"}
      ],
      "measures": [
        {"data_concept": "analysis_value", "role": "value"},
        {"data_concept": "change_value", "role": "value"},
        {"data_concept": "derivation_type", "role": "qualifier"}
      ]
    },

    "slice": {
      "name": "locf_slice",
      "constraints": [
        {"data_concept": "parameter", "value": "ACTOT11", "label": "ADAS-Cog(11) Total Score"},
        {"data_concept": "visit", "value": "Week 24"},
        {"data_concept": "visit_numeric", "value": 12}
      ]
    },

    "output_qualifier": {
      "data_concept": "derivation_type",
      "value": "LOCF",
      "condition": "When analysis_value is imputed from prior observation"
    }
  }
}
