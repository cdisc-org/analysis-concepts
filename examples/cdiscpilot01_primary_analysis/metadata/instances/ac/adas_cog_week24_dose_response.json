{
  "$schema": "https://cdisc.org/ac-dc/v1/instance-schema.json",
  "instance": {
    "id": "S_AC_CDISCPILOT01_ADAS_WK24",
    "name": "ADAS-Cog(11) Week 24 Primary Analysis - Dose Response",
    "type": "analysis_instance",
    "version": "1.0.0",
    "instance_of": "T_AC_ANCOVA_DoseResponse",
    "study": "CDISCPILOT01",
    "description": "Primary analysis of ADAS-Cog(11) change from baseline at Week 24 for efficacy population with LOCF imputation. ANCOVA model with baseline, site, and treatment dose (continuous) as predictors. Tests dose-response relationship.",
    "described_by": "S_SENTENCE_PRIMARY_ANALYSIS",
    "depends_on": [
      "S_DC_ADAS_Baseline",
      "S_DC_ADAS_Change",
      "S_DC_ADAS_LOCF",
      "S_DC_Efficacy"
    ],

    "method": {
      "name": "FitANCOVAModel",
      "formula": "change_value ~ baseline_value + site + treatment_dose"
    },

    "input_cube": {
      "name": "ancova_input",
      "dimensions": [
        {"data_concept": "subject", "role": "identifier"},
        {"data_concept": "treatment", "role": "factor"},
        {"data_concept": "site", "role": "factor"}
      ],
      "measures": [
        {"data_concept": "change_value", "role": "dependent"},
        {"data_concept": "baseline_value", "role": "covariate"},
        {"data_concept": "treatment_dose", "role": "continuous_predictor"}
      ]
    },

    "output_cubes": [
      {
        "name": "treatment_results",
        "description": "LS Means by Treatment Group",
        "dimensions": [
          {"data_concept": "treatment", "role": "identifier"}
        ],
        "measures": [
          {"data_concept": "ls_mean", "role": "value"},
          {"data_concept": "standard_error", "role": "value"},
          {"data_concept": "confidence_interval_lower", "role": "value"},
          {"data_concept": "confidence_interval_upper", "role": "value"}
        ]
      },
      {
        "name": "dose_response_results",
        "description": "Dose-Response Slope Estimate",
        "measures": [
          {"data_concept": "slope", "role": "value"},
          {"data_concept": "slope_se", "role": "value"},
          {"data_concept": "p_value", "role": "value"},
          {"data_concept": "confidence_interval_lower", "role": "value"},
          {"data_concept": "confidence_interval_upper", "role": "value"}
        ]
      }
    ],

    "slice": {
      "name": "ancova_slice",
      "constraints": [
        {"data_concept": "parameter", "value": "ACTOT11", "label": "ADAS-Cog(11) Total Score"},
        {"data_concept": "visit", "value": "Week 24"},
        {"data_concept": "efficacy_flag", "value": "Y", "label": "Efficacy Population"},
        {"data_concept": "derivation_type", "values": ["", "LOCF"], "description": "Include observed and LOCF-imputed values"}
      ]
    },

    "treatment_specification": {
      "values": [
        {"label": "Placebo", "dose_mg": 0},
        {"label": "Xanomeline Low Dose", "dose_mg": 54},
        {"label": "Xanomeline High Dose", "dose_mg": 81}
      ],
      "use_actual_dose": true,
      "description": "Treatment dose as continuous variable (0, 54, 81 mg)"
    },

    "model_specification": {
      "formula_notation": "Wilkinson-Rogers",
      "family": "Gaussian",
      "link": "Identity",
      "ss_type": "III"
    },

    "hypothesis": {
      "null": "beta_dose = 0 (no dose-response relationship)",
      "alternative": "beta_dose != 0 (dose-response exists)",
      "alpha": 0.05
    },

    "outputs": {
      "slope": {
        "description": "Slope estimate for treatment dose effect",
        "interpretation": "Change in ADAS-Cog(11) per unit increase in dose"
      },
      "slope_se": {
        "description": "Standard error of slope estimate"
      },
      "p_value": {
        "description": "P-value for test of dose-response trend",
        "interpretation": "P < 0.05 indicates significant dose-response relationship"
      },
      "confidence_interval": {
        "level": 0.95,
        "description": "95% CI for slope estimate"
      }
    }
  }
}
