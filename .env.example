# Copy this file to .env and fill in values. .env is gitignored.

# --- Neo4j (used by scripts/enrich_from_stato.py) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# --- CDISC Library (used by scripts/enrich_usdm_for_soa.py) ---
# Sent as the `api-key` request header.
CDISC_LIBRARY_API_KEY=
# Override only for testing / staging.
CDISC_LIBRARY_BASE_URL=https://api.library.cdisc.org/api/cosmos/v2
