    {
      "oid": "SP_POPULATION",
      "name": "Population",
      "role": "population",
      "phrase_template": "in the {population} population",
      "configurations": ["population"],
      "references": ["Population"]
    },
    {
      "oid": "SP_GROUPING",
      "name": "Treatment grouping",
      "role": "grouping",
      "phrase_template": "comparing {treatment} groups",
      "configurations": ["treatment"],
      "references": ["Treatment"]
    },
    {
      "oid": "SP_STRATIFICATION",
      "name": "Stratification",
      "role": "grouping",
      "phrase_template": "stratified by {strata}",
      "configurations": ["strata"],
      "references": []
