      "configurations": ["parameter"],
      "references": ["C.Flag", "Parameter"]
    },
    {
      "oid": "SP_VALUE_ENDPOINT",
      "name": "Analysis value endpoint",
      "role": "endpoint",
      "phrase_template": "{parameter} value",
      "configurations": ["parameter"],
      "references": ["C.Measure", "Parameter"]
    },
    {
      "oid": "SP_SHIFT_ENDPOINT",
      "name": "Shift endpoint",
      "role": "endpoint",
      "phrase_template": "shift from baseline in {parameter}",
      "configurations": ["parameter"],
      "references": ["C.Shift", "Parameter"]
    },
    {
      "oid": "SP_PEAK_ENDPOINT",
      "name": "Peak value endpoint",
      "role": "endpoint",
      "phrase_template": "peak {parameter}",
      "configurations": ["parameter"],
      "references": ["C.PeakValue", "Parameter"]
    },
    {
      "oid": "SP_AUC_ENDPOINT",
      "name": "Area under curve endpoint",
      "role": "endpoint",
      "phrase_template": "{parameter} AUC",
      "configurations": ["parameter"],
      "references": ["C.AreaUnderCurve", "Parameter"]
    },
    {
      "oid": "SP_PARAMETER",
      "name": "Parameter",
      "role": "parameter",
      "phrase_template": "for {parameter}",
      "configurations": ["parameter"],
      "references": ["Parameter"]
    },
    {
      "oid": "SP_TIMEPOINT",
      "name": "Timepoint",
      "role": "timepoint",
