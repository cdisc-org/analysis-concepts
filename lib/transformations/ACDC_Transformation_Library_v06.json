    {
      "oid": "SP_METHOD_LOGRANK",
      "name": "Log-rank method",
      "role": "method",
      "phrase_template": "using the log-rank test",
      "configurations": [],
      "references": ["M.LogRankTest"]
    },
    {
      "oid": "SP_METHOD_KM",
      "name": "Kaplan-Meier method",
      "role": "method",
      "phrase_template": "using Kaplan-Meier estimation",
      "configurations": [],
      "references": ["M.KaplanMeier"]
    },
    {
      "oid": "SP_METHOD_DESCSTATS",
      "name": "Descriptive statistics method",
      "role": "method",
      "phrase_template": "summarised by descriptive statistics",
      "configurations": [],
      "references": []
