{
  "version": "0.6",
  "description": "Transformation library using Option D (clinical naming with dimensional relationships) for DC concepts and AC Concept Model v0.16 for analysis concepts. SmartPhrases compose into human-readable analysis descriptions.",

  "$references": {
    "dcConcepts": "Option_D_Clinical_with_Dimensions.json",
    "acConcepts": "AC_Concept_Model_v016.json",
    "methods": "Method definitions (M.MMRM, M.LogRankTest, M.Subtraction, etc.)"
  },

  "smartPhrases": [
    {
      "oid": "SP_CFB_ENDPOINT",
      "name": "Change from baseline endpoint",
      "role": "endpoint",
      "phrase_template": "change from baseline in {parameter}",
      "configurations": ["parameter"],
      "references": ["C.Change", "Parameter"]
    },
    {
      "oid": "SP_PCTCFB_ENDPOINT",
      "name": "Percent change from baseline endpoint",
      "role": "endpoint",
      "phrase_template": "percent change from baseline in {parameter}",
      "configurations": ["parameter"],
      "references": ["C.PercentChange", "Parameter"]
    },
    {
      "oid": "SP_TTE_ENDPOINT",
      "name": "Time-to-event endpoint",
      "role": "endpoint",
      "phrase_template": "time to {event}",
      "configurations": ["event"],
