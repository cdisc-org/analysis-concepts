{
  "$schema": "../../model/method/method_implementation_catalog.schema.json",
  "model": "MethodImplementationCatalog",
  "version": "0.1.0",
  "description": "R implementations for analysis methods. Migrated from stato_r_implementation fields.",
  "implementations": {
    "M.PairedTTest": [
      {
        "methodOid": "M.PairedTTest",
        "language": "R",
        "package": "stats",
        "function": "t.test",
        "callTemplate": "t.test(<response> ~ <fixed_effect>, data = <dataset>, paired = TRUE, var.equal = FALSE, conf.level = <conf_level>)",
        "outputMapping": [
          {
            "outputClass": "test_result",
            "resultColumns": {
              "estimate": "estimate",
              "t_statistic": "statistic",
              "df": "parameter",
              "p_value": "p.value",
              "CI_lower": "conf.int[1]",
              "CI_upper": "conf.int[2]"
            }
          }
        ],
        "documentation": "https://stat.ethz.ch/R-manual/R-patched/library/stats/html/t.test.html",
        "notes": "Paired t-test via formula interface. The repeated_subject pairing is implicit in data ordering or handled via the paired=TRUE argument."
      }
    ],
    "M.OneSampleTTest": [
      {
        "methodOid": "M.OneSampleTTest",
        "language": "R",
        "package": "stats",
        "function": "t.test",
        "callTemplate": "t.test(x = <response>, mu = <mu>, alternative = <alternative>, conf.level = <conf_level>)",
        "outputMapping": [
          {
            "outputClass": "test_result",
            "resultColumns": {
              "estimate": "estimate",
              "t_statistic": "statistic",
              "df": "parameter",
              "p_value": "p.value",
              "CI_lower": "conf.int[1]",
              "CI_upper": "conf.int[2]"
            }
          }
        ],
        "documentation": "https://stat.ethz.ch/R-manual/R-patched/library/stats/html/t.test.html",
        "notes": "One-sample t-test. Tests whether the mean of x differs from mu."
      }
    ],
    "M.TwoSampleTTest": [
      {
        "methodOid": "M.TwoSampleTTest",
        "language": "R",
        "package": "stats",
        "function": "t.test",
        "callTemplate": "t.test(<response> ~ <fixed_effect>, data = <dataset>, paired = FALSE, var.equal = FALSE, alternative = <alternative>, conf.level = <conf_level>)",
        "outputMapping": [
          {
            "outputClass": "test_result",
            "resultColumns": {
              "estimate": "estimate",
              "t_statistic": "statistic",
              "df": "parameter",
              "p_value": "p.value",
              "CI_lower": "conf.int[1]",
              "CI_upper": "conf.int[2]"
            }
          }
        ],
        "documentation": "https://stat.ethz.ch/R-manual/R-patched/library/stats/html/t.test.html",
        "notes": "Two-sample (Welch) t-test via formula interface. fixed_effect must have exactly two levels."
      }
    ],
    "M.FisherExactTest": [
      {
        "methodOid": "M.FisherExactTest",
        "language": "R",
        "package": "stats",
        "function": "fisher.test",
        "callTemplate": "fisher.test(table(<response>, <fixed_effect>))",
        "outputMapping": [
          {
            "outputClass": "test_result",
            "resultColumns": {
              "p_value": "p.value",
              "estimate": "estimate"
            }
          }
        ],
        "documentation": "https://stat.ethz.ch/R-manual/R-patched/library/stats/html/fisher.test.html",
        "notes": "Fisher's exact test for 2x2 contingency tables. Both response and fixed_effect must be categorical/binary."
      }
    ],
    "M.ANCOVA": [
      {
        "methodOid": "M.ANCOVA",
        "language": "R",
        "packages": ["stats", "car", "emmeans"],
        "function": "lm",
        "callTemplate": "model <- lm(<response> ~ <covariate> + <fixed_effect>, data = <dataset>)\nmodel_summary <- summary(model)\nanova_result <- car::Anova(model, type = \"<ss_type>\")\nlsm <- emmeans::emmeans(model, ~ <fixed_effect>)\nlsm_df <- as.data.frame(summary(lsm, infer = TRUE, level = 1 - <alpha>))\ncontr <- pairs(lsm, adjust = \"<multiplicity_adjustment>\")\ncontr_df <- as.data.frame(summary(contr, infer = TRUE, level = 1 - <alpha>))",
        "outputMapping": [
          {
            "outputClass": "fit_statistics",
            "resultColumns": {
              "R_squared": "model_summary$r.squared",
              "Adj_R_squared": "model_summary$adj.r.squared",
              "AIC": "AIC(model)",
              "BIC": "BIC(model)"
            }
          },
          {
            "outputClass": "type3_tests",
            "resultColumns": {
              "Term": "rownames(anova_result)",
              "SS": "anova_result[['Sum Sq']]",
              "df": "anova_result[['Df']]",
              "F_statistic": "anova_result[['F value']]",
              "p_value": "anova_result[['Pr(>F)']]"
            }
          },
          {
            "outputClass": "ls_means",
            "resultColumns": {
              "Group": "lsm_df[[1]]",
              "estimate": "lsm_df$emmean",
              "SE": "lsm_df$SE",
              "df": "lsm_df$df",
              "CI_lower": "lsm_df$lower.CL",
              "CI_upper": "lsm_df$upper.CL"
            }
          },
          {
            "outputClass": "contrasts",
            "resultColumns": {
              "Contrast": "as.character(contr_df$contrast)",
              "estimate": "contr_df$estimate",
              "SE": "contr_df$SE",
              "df": "contr_df$df",
              "CI_lower": "contr_df$lower.CL",
              "CI_upper": "contr_df$upper.CL",
              "t_statistic": "contr_df$t.ratio",
              "p_value": "contr_df$p.value"
            }
          },
          {
            "outputClass": "covariance_parameters",
            "resultColumns": {
              "residual_variance": "sum(model$residuals^2) / model$df.residual"
            }
          }
        ],
        "documentation": "https://stat.ethz.ch/R-manual/R-patched/library/stats/html/lm.html",
        "notes": "ANCOVA via lm() with Type III SS from car::Anova() and LS means from emmeans. Covariate adjusts the group comparison."
      }
    ]
  }
}
