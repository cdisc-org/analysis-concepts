{
  "$schema": "../../../model/json_schema/acdc_method.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "conceptId": "M.WindowLookup",
  "name": "Window Lookup",
  "label": "Window Lookup",
  "ncitCode": null,
  "description": "Retrieves value from another row within partition",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := LAG(value, 1) OVER (partition ORDER BY order_by)",
    "generic_expression": "result := <window_func>(<value>, <offset>?) OVER (<partition>+ ORDER BY <order_by>)"
  },
  "configurations": [
    {
      "name": "window_func",
      "dataType": "enum",
      "defaultValue": "lag",
      "enumValues": [
        "lag",
        "lead",
        "first",
        "last"
      ],
      "description": "Window function type"
    },
    {
      "name": "offset",
      "dataType": "decimal",
      "defaultValue": 1,
      "description": "Row offset for lag/lead"
    },
    {
      "name": "order_by",
      "dataType": "code",
      "description": "Variable defining row order within partition"
    }
  ],
  "inputs": [
    {
      "name": "value",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "Value to look up"
    },
    {
      "name": "partition",
      "dataType": "code",
      "required": true,
      "cardinality": "multiple",
      "description": "Partitioning variables"
    }
  ],
  "outputs": [
    {
      "output_type": "computed_value",
      "name": "result",
      "indexed_by": [
        "partition"
      ],
      "unit_policy": "preserved",
      "dataType": "decimal"
    }
  ]
}
