{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "name": "M.AffineTransform",
  "label": "Affine Transform",
  "code": {
    "system": "NCI",
    "value": null
  },
  "type": "derivation",
  "class": "Arithmetic",
  "intent": [
    "Rescaling"
  ],
  "description": "Per-row affine transform: result = scale * value + offset. Used for any linear rescaling on a single column (e.g. (70 - x)/70 with scale=-1/70, offset=1, percent-of-max conversions, unit shifts).",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := scale * value + offset",
    "generic_expression": "result := <scale> * <value> + <offset>"
  },
  "unit_policy": "preserved",
  "configurations": [
    {
      "name": "scale",
      "dataType": "decimal",
      "defaultValue": 1,
      "description": "Multiplier applied to the input value"
    },
    {
      "name": "offset",
      "dataType": "decimal",
      "defaultValue": 0,
      "description": "Constant added after the multiplication"
    }
  ],
  "methodInput": [
    {
      "name": "value",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "Per-row numeric input to be rescaled"
    }
  ],
  "methodOutput": [
    {
      "output_type": "fhir:Quantity",
      "name": "derived_value"
    }
  ],
  "assumptions": []
}
