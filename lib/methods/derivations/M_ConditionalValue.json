{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "name": "M.ConditionalValue",
  "label": "Conditional Value",
  "code": {
    "system": "NCI",
    "value": null
  },
  "type": "derivation",
  "class": "Data Handling",
  "intent": [
    "Masking",
    "MissingnessHandling"
  ],
  "description": "Per-row conditional. If the input value is NA (missing), output the alternate value; else output the configured base value (default 0).",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := IF(IS_NA(value), alternate, base)",
    "generic_expression": "result := IF(IS_NA(<value>), <alternate>, <base>)"
  },
  "unit_policy": "preserved",
  "configurations": [
    {
      "name": "base",
      "dataType": "decimal",
      "defaultValue": 0,
      "description": "Value emitted when the input is NOT missing"
    }
  ],
  "methodInput": [
    {
      "name": "value",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "Per-row value tested for missingness (NA)"
    },
    {
      "name": "alternate",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "Per-row replacement value used when value is NA"
    }
  ],
  "methodOutput": [
    {
      "output_type": "fhir:Quantity",
      "name": "derived_value"
    }
  ],
  "assumptions": []
}
