{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.4.0",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "oid": "M.PercentChange",
  "name": "Percent Change",
  "type": "derivation",
  "class": "Arithmetic",
  "intent": [
    "ChangeComputation"
  ],
  "description": "Computes proportional change as a percentage",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := 100 * (post - pre) / pre",
    "generic_expression": "result := 100 * (<post> - <pre>) / <pre>"
  },
  "configurations": [],
  "assumptions": [
    "Pre value is non-zero"
  ],
  "input_roles": [
    {
      "name": "pre",
      "dataType": "numeric",
      "required": true,
      "cardinality": "single",
      "description": "The baseline/reference value"
    },
    {
      "name": "post",
      "dataType": "numeric",
      "required": true,
      "cardinality": "single",
      "description": "The post-baseline value"
    }
  ],
  "output_specification": {
    "output_classes": [
      {
        "class": "computed_value",
        "role_name": "result",
        "dataType": "numeric",
        "description": "Result: 100 * (post - pre) / pre",
        "statistics": [
          "value"
        ],
        "indexed_by": null
      }
    ]
  }
}
