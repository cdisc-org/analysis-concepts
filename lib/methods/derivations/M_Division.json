      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The value to divide"
    },
    {
      "name": "denominator",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The value to divide by"
    }
  ],
  "outputs": [
    {
      "output_type": "computed_value",
