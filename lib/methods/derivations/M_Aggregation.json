{
  "$schema": "../../../model/json_schema/acdc_method.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "conceptId": "M.Aggregation",
  "name": "Aggregation",
  "label": "Aggregation",
  "ncitCode": null,
  "description": "Aggregates values within a partition using specified function",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := AGG(value) OVER (partition)",
    "generic_expression": "result := <agg_func>(<value>) OVER (<partition>+)"
  },
  "configurations": [
    {
      "name": "agg_func",
      "dataType": "enum",
      "defaultValue": "mean",
      "enumValues": [
        "sum",
        "mean",
        "median",
        "min",
        "max",
        "count",
        "first",
        "last"
      ],
      "description": "Aggregation function to apply"
    }
  ],
  "inputs": [
    {
      "name": "value",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "Values to aggregate"
    },
    {
      "name": "partition",
      "dataType": "code",
      "required": true,
      "cardinality": "multiple",
      "description": "Grouping variables defining the partition"
    }
  ],
  "outputs": [
    {
      "output_type": "computed_value",
      "name": "result",
      "indexed_by": [
        "partition"
      ],
      "unit_policy": "preserved",
      "dataType": "decimal"
    }
  ]
}
