      "description": "The value to subtract from"
    },
    {
      "name": "subtrahend",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The value to subtract"
    }
  ],
  "outputs": [
    {
      "output_type": "computed_value",
