{
  "$schema": "../../../model/json_schema/acdc_method.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "conceptId": "M.GeometricMean",
  "name": "Geometric Mean",
  "label": "GeoMean",
  "ncitCode": null,
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO_0000396",
      "display": "geometric mean"
    }
  ],
  "description": "Computes the geometric mean (exp of mean of log values) of a numeric variable",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := GEOMEAN(value) OVER (group)",
    "generic_expression": "result := GEOMEAN(<value>) OVER (<group>*)"
  },
  "inputs": [
    {
      "name": "value",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The variable to summarize"
    },
    {
      "name": "group",
      "dataType": "code",
      "required": false,
      "cardinality": "multiple",
      "description": "Optional grouping variable(s)"
    }
  ],
  "outputs": [
    {
      "output_type": "computed_value",
      "name": "result",
      "indexed_by": [
        "group"
      ],
      "unit_policy": "preserved",
      "dataType": "decimal"
    }
  ]
}
