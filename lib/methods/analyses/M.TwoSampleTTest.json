{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.5.0",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "oid": "M.TwoSampleTTest",
  "name": "Two-sample t-test",
  "type": "analysis",
  "class": "General Linear Models",
  "intent": [
    "GroupComparison"
  ],
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO:0000304",
      "relationship": "equivalent"
    },
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO:0000279",
      "display": "between group comparison statistical test",
      "relationship": "parent"
    }
  ],
  "stato_r_implementation": "t.test(x, y = NULL,\n       alternative = c(\"two.sided\", \"less\", \"greater\"),\n       mu = 0, paired = FALSE, var.equal = FALSE,\n       conf.level = 0.95, ...)\n\nhttp://stat.ethz.ch/R-manual/R-patched/library/stats/html/t.test.html",
  "description": "Tests whether means of two independent samples differ significantly",
  "formula": {
    "notation": "wilkinson_rogers",
    "default_expression": "response ~ group",
    "generic_expression": "<response> ~ <group>",
    "notes": "Single factor with exactly two levels"
  },
  "configurations": [
    {
      "name": "var_equal",
      "dataType": "boolean",
      "defaultValue": false,
      "description": "Assume equal variances (true=pooled, false=Welch)"
    },
    {
      "name": "alternative",
      "dataType": "enum",
      "defaultValue": "two_sided",
      "enumValues": [
        "two_sided",
        "less",
        "greater"
      ],
      "description": "Direction of alternative hypothesis"
    },
    {
      "name": "conf_level",
      "dataType": "numeric",
      "defaultValue": 0.95,
      "description": "Confidence level"
    }
  ],
  "output_specification": {
    "output_classes": [
      {
        "class": "test_result",
        "description": "Two-sample t-test result",
        "cardinality": "singleton",
        "indexed_by": null,
        "statistics": [
          "t_statistic",
          "p_value",
          "df"
        ]
      },
      {
        "class": "ls_means",
        "description": "Group means",
        "cardinality": "per_level",
        "indexed_by": [
          "group"
        ],
        "statistics": [
          "mean",
          "SE",
          "CI_lower",
          "CI_upper"
        ]
      },
      {
        "class": "contrasts",
        "description": "Difference between group means",
        "cardinality": "singleton",
        "indexed_by": null,
        "statistics": [
          "estimate",
          "SE",
          "CI_lower",
          "CI_upper",
          "t_statistic",
          "p_value",
          "df"
        ]
      }
    ]
  },
  "assumptions": [
    "Normality within groups",
    "Independence of observations",
    "Equal variances (if var_equal=true)"
  ],
  "input_roles": [
    {
      "name": "response",
      "statisticalRole": "response",
      "dataType": "numeric",
      "required": true,
      "cardinality": "single",
      "description": "The response variable"
    },
    {
      "name": "group",
      "statisticalRole": "fixed_effect",
      "dataType": "string",
      "required": true,
      "cardinality": "single",
      "description": "Grouping variable (exactly two levels)"
    }
  ]
}
