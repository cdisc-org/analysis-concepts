{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.8.0",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "oid": "M.LogisticRegression",
  "name": "Logistic Regression",
  "type": "analysis",
  "class": "Generalized Linear Models",
  "intent": [
    "OutcomeModeling"
  ],
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO_0000149",
      "display": "binomial logistic regression for analysis of dichotomous dependent variable"
    }
  ],
  "description": "Models binary outcome as function of predictors via a link function (logit by default)",
  "formula": {
    "notation": "wilkinson_rogers",
    "default_expression": "response ~ covariate + fixed_effect",
    "generic_expression": "<response> ~ <covariate>* + <fixed_effect>+ + (<covariate>:<fixed_effect>)* + (<fixed_effect>:<fixed_effect>)*",
    "notes": "Generalized linear model with binomial family. Multiple covariates and factors supported. For stratified analyses, can include strata as a fixed effect."
  },
  "configurations": [
    {
      "name": "link",
      "dataType": "enum",
      "defaultValue": "logit",
      "enumValues": [
        "logit",
        "probit",
        "cloglog"
      ],
      "description": "Link function"
    }
  ],
  "output_specification": {
    "output_classes": [
      {
        "class": "fit_statistics",
        "description": "Model fit measures",
        "dimensions": null,
        "statistics": [
          "AIC",
          "BIC",
          "minus2LogL",
          "concordance"
        ]
      },
      {
        "class": "type3_tests",
        "description": "Type III likelihood ratio or Wald tests per term",
        "dimensions": [
          "covariate",
          "fixed_effect",
          "covariate:fixed_effect",
          "fixed_effect:fixed_effect"
        ],
        "statistics": [
          "chi_squared",
          "p_value",
          "df"
        ],
        "configurations": [
          {
            "name": "multiplicity_adjustment",
            "conforms_to": "multiplicity_adjustment",
            "applicable_scopes": [
              "universal"
            ]
          }
        ]
      },
      {
        "class": "parameter_estimates",
        "description": "Maximum likelihood estimates on log-odds scale",
        "dimensions": [
          "covariate",
          "fixed_effect",
          "covariate:fixed_effect",
          "fixed_effect:fixed_effect"
        ],
        "statistics": [
          "coefficient",
          "SE",
          "z_statistic",
          "p_value",
          "CI_lower",
          "CI_upper",
          "odds_ratio"
        ],
        "configurations": [
          {
            "name": "multiplicity_adjustment",
            "conforms_to": "multiplicity_adjustment",
            "applicable_scopes": [
              "universal"
            ]
          }
        ]
      },
      {
        "class": "odds_ratio_estimates",
        "description": "Odds ratios with confidence intervals (exponentiated coefficients)",
        "dimensions": [
          "covariate",
          "fixed_effect",
          "covariate:fixed_effect",
          "fixed_effect:fixed_effect"
        ],
        "statistics": [
          "odds_ratio",
          "CI_lower",
          "CI_upper"
        ]
      }
    ]
  },
  "assumptions": [
    "Independence of observations",
    "Linear relationship between log-odds and predictors",
    "No multicollinearity"
  ],
  "input_roles": [
    {
      "name": "response",
      "statisticalRole": "response",
      "dataType": "code",
      "required": true,
      "cardinality": "single",
      "description": "Binary response variable (0/1 or event/no-event)"
    },
    {
      "name": "covariate",
      "statisticalRole": "covariate",
      "dataType": "decimal",
      "required": false,
      "cardinality": "multiple",
      "description": "Continuous covariate(s)"
    },
    {
      "name": "fixed_effect",
      "statisticalRole": "fixed_effect",
      "dataType": "code",
      "required": true,
      "cardinality": "single_or_multiple",
      "description": "Treatment group and/or other categorical factors"
    }
  ]
}
