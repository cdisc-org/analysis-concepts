{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.8.0",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json",
    "configuration_concepts": "../../model/method/configuration_concepts.json"
  },
  "oid": "M.CoxPH",
  "name": "Cox Proportional Hazards",
  "type": "analysis",
  "class": "Survival Models",
  "intent": [
    "TimeToEventEstimate"
  ],
  "description": "Semi-parametric regression for survival data modeling the hazard function",
  "formula": {
    "notation": "survival",
    "default_expression": "Surv(time, event) ~ covariate + fixed_effect",
    "generic_expression": "Surv(<time>, <event>) ~ <covariate>* + <fixed_effect>+ + (<covariate>:<fixed_effect>)* + strata(<strata>)*",
    "notes": "Multiple covariates, factors, and interactions supported. The strata() function creates a stratified baseline hazard (one per stratum level) without estimating a coefficient for that variable."
  },
  "configurations": [
    {
      "name": "ties",
      "dataType": "enum",
      "defaultValue": "efron",
      "enumValues": [
        "efron",
        "breslow",
        "exact"
      ],
      "description": "Method for handling tied event times"
    }
  ],
  "output_specification": {
    "output_classes": [
      {
        "class": "fit_statistics",
        "description": "Model fit and global tests",
        "dimensions": null,
        "statistics": [
          "minus2LogL",
          "AIC",
          "BIC",
          "concordance"
        ]
      },
      {
        "class": "global_tests",
        "description": "Overall model significance tests (likelihood ratio, Wald, score)",
        "dimensions": null,
        "statistics": [
          "chi_squared",
          "p_value",
          "df"
        ],
        "test_types": [
          "likelihood_ratio",
          "wald",
          "score"
        ]
      },
      {
        "class": "type3_tests",
        "description": "Type III Wald tests per model term",
        "dimensions": [
          "covariate",
          "fixed_effect",
          "covariate:fixed_effect"
        ],
        "statistics": [
          "chi_squared",
          "p_value",
          "df"
        ],
        "configurations": [
          {
            "name": "multiplicity_adjustment",
            "conforms_to": "multiplicity_adjustment",
            "applicable_scopes": [
              "universal"
            ]
          }
        ]
      },
      {
        "class": "parameter_estimates",
        "description": "Regression coefficients on log-hazard scale with hazard ratios",
        "dimensions": [
          "covariate",
          "fixed_effect",
          "covariate:fixed_effect"
        ],
        "statistics": [
          "coefficient",
          "SE",
          "z_statistic",
          "p_value",
          "hazard_ratio",
          "CI_lower",
          "CI_upper"
        ],
        "configurations": [
          {
            "name": "multiplicity_adjustment",
            "conforms_to": "multiplicity_adjustment",
            "applicable_scopes": [
              "universal"
            ]
          }
        ]
      },
      {
        "class": "hazard_ratio_estimates",
        "description": "Hazard ratios with confidence intervals (exponentiated coefficients)",
        "dimensions": [
          "covariate",
          "fixed_effect",
          "covariate:fixed_effect"
        ],
        "statistics": [
          "hazard_ratio",
          "CI_lower",
          "CI_upper"
        ]
      }
    ]
  },
  "assumptions": [
    "Proportional hazards",
    "Non-informative censoring",
    "Independence of survival times"
  ],
  "input_roles": [
    {
      "name": "time",
      "statisticalRole": "response",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "Time to event or censoring"
    },
    {
      "name": "event",
      "statisticalRole": "response",
      "dataType": "boolean",
      "required": true,
      "cardinality": "single",
      "description": "Event indicator"
    },
    {
      "name": "covariate",
      "statisticalRole": "covariate",
      "dataType": "decimal",
      "required": false,
      "cardinality": "multiple",
      "description": "Continuous covariate(s)"
    },
    {
      "name": "fixed_effect",
      "statisticalRole": "fixed_effect",
      "dataType": "code",
      "required": true,
      "cardinality": "single_or_multiple",
      "description": "Treatment group and/or other categorical factors"
    },
    {
      "name": "strata",
      "statisticalRole": "strata",
      "dataType": "code",
      "required": false,
      "cardinality": "multiple",
      "description": "Stratification variable(s) for stratified Cox model"
    }
  ]
}
