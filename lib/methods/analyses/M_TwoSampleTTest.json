{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json",
    "configuration_concepts": "../../model/method/configuration_concepts.json"
  },
  "name": "M.TwoSampleTTest",
  "label": "Two-sample t-test",
  "code": {
    "system": "NCI",
    "value": null
  },
  "type": "analysis",
  "class": "General Linear Models",
  "intent": [
    "GroupComparison"
  ],
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO_0000304",
      "display": "two sample t-test"
    }
  ],
  "description": "Tests whether means of two independent samples differ significantly",
  "formula": {
    "notation": "wilkinson_rogers",
    "default_expression": "response ~ fixed_effect",
    "generic_expression": "<response> ~ <fixed_effect>",
    "notes": "Single factor with exactly two levels"
  },
  "configurations": [
    {
      "name": "var_equal",
      "dataType": "boolean",
      "defaultValue": false,
      "description": "Assume equal variances (true=pooled, false=Welch)"
    },
    {
      "name": "alternative",
      "dataType": "enum",
      "defaultValue": "two_sided",
      "enumValues": [
        "two_sided",
        "less",
        "greater"
      ],
      "description": "Direction of alternative hypothesis"
    },
    {
      "name": "conf_level",
      "conforms_to": "conf_level"
    }
  ],
  "methodInput": [
    {
      "name": "response",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The response variable"
    },
    {
      "name": "fixed_effect",
      "dataType": "code",
      "required": true,
      "cardinality": "single",
      "description": "Grouping variable (exactly two levels)"
    }
  ],
  "methodOutput": [
    {
      "name": "t_test_result",
      "output_type": "t_test_result"
    },
    {
      "name": "ls_means",
      "output_type": "ls_means",
      "indexed_by": [
        "fixed_effect"
      ]
    },
    {
      "name": "contrasts_t",
      "output_type": "contrasts_t"
    }
  ],
  "assumptions": [
    "Normality within groups",
    "Independence of observations",
    "Equal variances (if var_equal=true)"
  ]
}
