{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.5.0",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "oid": "M.Proportion",
  "name": "Proportion",
  "type": "analysis",
  "class": "Counting",
  "intent": ["DescriptiveSummary"],
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO_0000607",
      "display": "proportion"
    }
  ],
  "description": "Computes the proportion and percentage per category of a categorical variable",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := PROP(category) OVER (group)",
    "generic_expression": "result := PROP(<category>) OVER (<group>*)"
  },
  "configurations": [
    {
      "name": "ci_method",
      "dataType": "enum",
      "defaultValue": "exact_clopper_pearson",
      "enumValues": ["exact_clopper_pearson", "wilson", "wald", "agresti_coull", "jeffreys"],
      "description": "Method for confidence interval calculation"
    },
    {
      "name": "ci_level",
      "dataType": "numeric",
      "defaultValue": 0.95,
      "description": "Confidence level"
    }
  ],
  "output_specification": {
    "output_classes": [
      {
        "class": "computed_value",
        "description": "The proportion, percentage, and confidence interval per category per group",
        "cardinality": "per_group",
        "indexed_by": ["group"],
        "statistics": ["proportion", "pct", "CI_lower", "CI_upper"]
      }
    ]
  },
  "assumptions": [],
  "input_roles": [
    {
      "name": "category",
      "statisticalRole": "response",
      "dataType": "string",
      "required": true,
      "cardinality": "single",
      "description": "The categorical variable to summarize"
    },
    {
      "name": "group",
      "statisticalRole": "fixed_effect",
      "dataType": "string",
      "required": false,
      "cardinality": "single_or_multiple",
      "description": "Optional grouping variable(s)"
    }
  ]
}
