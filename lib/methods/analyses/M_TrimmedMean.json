{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "name": "M.TrimmedMean",
  "label": "Trimmed Mean",
  "code": {
    "system": "NCI",
    "value": null
  },
  "type": "analysis",
  "class": "Central Tendency",
  "intent": [
    "DescriptiveSummary"
  ],
  "description": "Computes the trimmed mean after removing a fraction of extreme values from each tail",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := TRIMMEAN(response, trim_fraction) OVER (group)",
    "generic_expression": "result := TRIMMEAN(<response>, <trim_fraction>) OVER (<group>*)"
  },
  "unit_policy": "preserved",
  "configurations": [
    {
      "name": "trim_fraction",
      "dataType": "decimal",
      "defaultValue": 0.05,
      "description": "Fraction to trim from each tail (0 to 0.5)"
    }
  ],
  "methodInput": [
    {
      "name": "response",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The variable to summarize"
    },
    {
      "name": "group",
      "dataType": "code",
      "required": false,
      "cardinality": "single_or_multiple",
      "description": "Optional grouping variable(s)"
    }
  ],
  "methodOutput": [
    {
      "output_type": "fhir:Quantity",
      "name": "derived_value",
      "indexed_by": [
        "group"
      ]
    }
  ],
  "assumptions": []
}
