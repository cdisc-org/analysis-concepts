{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "name": "M.WinsorizedMean",
  "label": "Winsorized Mean",
  "code": {
    "system": "NCI",
    "value": null
  },
  "type": "analysis",
  "class": "Central Tendency",
  "intent": [
    "DescriptiveSummary"
  ],
  "description": "Computes the Winsorized mean after replacing extreme values with boundary values",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := WINMEAN(response, winsor_fraction) OVER (group)",
    "generic_expression": "result := WINMEAN(<response>, <winsor_fraction>) OVER (<group>*)"
  },
  "unit_policy": "preserved",
  "configurations": [
    {
      "name": "winsor_fraction",
      "dataType": "decimal",
      "defaultValue": 0.05,
      "description": "Fraction to Winsorize from each tail (0 to 0.5)"
    }
  ],
  "methodInput": [
    {
      "name": "response",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The variable to summarize"
    },
    {
      "name": "group",
      "dataType": "code",
      "required": false,
      "cardinality": "single_or_multiple",
      "description": "Optional grouping variable(s)"
    }
  ],
  "methodOutput": [
    {
      "output_type": "fhir:Quantity",
      "name": "derived_value",
      "indexed_by": [
        "group"
      ]
    }
  ],
  "assumptions": []
}
