{
  "$schema": "../../../model/json_schema/acdc_method.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "conceptId": "M.WinsorizedMean",
  "name": "Winsorized Mean",
  "label": "Winsorized Mean",
  "ncitCode": null,
  "description": "Computes the Winsorized mean after replacing extreme values with boundary values",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := WINMEAN(value, winsor_fraction) OVER (group)",
    "generic_expression": "result := WINMEAN(<value>, <winsor_fraction>) OVER (<group>*)"
  },
  "configurations": [
    {
      "name": "winsor_fraction",
      "dataType": "decimal",
      "defaultValue": 0.05,
      "description": "Fraction to Winsorize from each tail (0 to 0.5)"
    }
  ],
  "inputs": [
    {
      "name": "value",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The variable to summarize"
    },
    {
      "name": "group",
      "dataType": "code",
      "required": false,
      "cardinality": "multiple",
      "description": "Optional grouping variable(s)"
    }
  ],
  "outputs": [
    {
      "output_type": "computed_value",
      "name": "result",
      "indexed_by": [
        "group"
      ],
      "unit_policy": "preserved",
      "dataType": "decimal"
    }
  ]
}
