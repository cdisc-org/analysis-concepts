{
  "$schema": "../../../model/json_schema/acdc_method.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "conceptId": "M.Quartile",
  "name": "Quartile",
  "label": "Quartile",
  "ncitCode": null,
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO_0000152",
      "display": "quartile"
    }
  ],
  "description": "Computes the first quartile (Q1) and third quartile (Q3)",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := QUARTILE(value) OVER (group)",
    "generic_expression": "result := QUARTILE(<value>) OVER (<group>*)"
  },
  "inputs": [
    {
      "name": "value",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The variable to summarize"
    },
    {
      "name": "group",
      "dataType": "code",
      "required": false,
      "cardinality": "multiple",
      "description": "Optional grouping variable(s)"
    }
  ],
  "outputs": [
    {
      "output_type": "computed_value",
      "name": "result",
      "indexed_by": [
        "group"
      ],
      "unit_policy": "preserved",
      "dataType": "decimal"
    }
  ]
}
