  },
  "oid": "M.Mode",
  "name": "Mode",
  "type": "analysis",
  "class": "Central Tendency",
  "intent": ["DescriptiveSummary"],
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO_0000033",
      "display": "mode"
    }
  ],
  "description": "Determines the most frequently occurring value",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := MODE(variable) OVER (group)",
    "generic_expression": "result := MODE(<variable>) OVER (<group>*)"
  },
  "configurations": [],
  "output_specification": {
    "output_classes": [
      {
        "class": "computed_value",
        "description": "Mode of the variable",
        "cardinality": "per_group",
        "indexed_by": ["group"],
        "statistics": ["mode"]
      }
    ]
  },
  "assumptions": [],
  "input_roles": [
    {
      "name": "variable",
      "statisticalRole": "response",
      "dataType": "numeric",
      "required": true,
      "cardinality": "single",
      "description": "The variable to summarize"
    },
    {
      "name": "group",
      "statisticalRole": "fixed_effect",
      "dataType": "string",
      "required": false,
      "cardinality": "single_or_multiple",
      "description": "Optional grouping variable(s)"
    }
  ]
