{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.7.0",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "oid": "M.ANCOVA",
  "name": "ANCOVA",
  "type": "analysis",
  "class": "General Linear Models",
  "intent": [
    "GroupComparison"
  ],
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO_0000179",
      "display": "ANCOVA"
    }
  ],
  "description": "Analysis of Covariance - ANOVA with continuous covariate adjustment",
  "formula": {
    "notation": "wilkinson_rogers",
    "default_expression": "response ~ covariate + fixed_effect",
    "generic_expression": "<response> ~ <covariate>* + <fixed_effect>+ + (<fixed_effect>:<fixed_effect>)* + (<covariate>:<fixed_effect>)*",
    "notes": "Covariates adjust the group comparison. Adding covariate:fixed_effect interaction tests homogeneity of regression slopes. Multiple covariates and factors are supported."
  },
  "configurations": [
    {
      "name": "ss_type",
      "dataType": "enum",
      "defaultValue": "III",
      "enumValues": [
        "I",
        "II",
        "III",
        "IV"
      ],
      "description": "Sum of squares type"
    },
    {
      "name": "alpha",
      "dataType": "decimal",
      "defaultValue": 0.05,
      "description": "Significance level"
    },
    {
      "name": "multiplicity_adjustment",
      "dataType": "enum",
      "defaultValue": "None",
      "enumValues": ["None", "Tukey", "Bonferroni", "Holm", "Dunnett", "Sidak"],
      "description": "Multiplicity adjustment method for pairwise comparisons",
      "codings": [
        { "system": "http://purl.obolibrary.org/obo/stato", "code": "STATO_0000182", "display": "Tukey" },
        { "system": "http://purl.obolibrary.org/obo/stato", "code": "STATO_0000067", "display": "Bonferroni" },
        { "system": "http://purl.obolibrary.org/obo/stato", "code": "STATO_0000068", "display": "Holm" },
        { "system": "http://purl.obolibrary.org/obo/stato", "code": "STATO_0000183", "display": "Dunnett" }
      ]
    }
  ],
  "output_specification": {
    "output_classes": [
      {
        "class": "fit_statistics",
        "description": "Model fit measures",
        "cardinality": "singleton",
        "dimensions": null,
        "statistics": [
          "AIC",
          "BIC",
          "minus2LogL",
          "R_squared"
        ]
      },
      {
        "class": "type3_tests",
        "description": "Type III tests for each model term (covariate, group, interactions)",
        "cardinality": "per_term",
        "dimensions": [
          "covariate",
          "fixed_effect",
          "fixed_effect:fixed_effect",
          "covariate:fixed_effect"
        ],
        "statistics": [
          "SS",
          "df_num",
          "df_den",
          "MS",
          "F_statistic",
          "p_value"
        ]
      },
      {
        "class": "parameter_estimates",
        "description": "Solution for fixed effects (intercept, covariate slopes, group effects)",
        "cardinality": "per_coefficient",
        "dimensions": [
          "covariate",
          "fixed_effect",
          "fixed_effect:fixed_effect",
          "covariate:fixed_effect"
        ],
        "statistics": [
          "coefficient",
          "SE",
          "t_statistic",
          "p_value",
          "CI_lower",
          "CI_upper",
          "df"
        ]
      },
      {
        "class": "ls_means",
        "description": "Least-squares means per group level, adjusted for covariates",
        "cardinality": "per_level",
        "dimensions": [
          "fixed_effect"
        ],
        "statistics": [
          "estimate",
          "SE",
          "CI_lower",
          "CI_upper",
          "df"
        ]
      },
      {
        "class": "contrasts",
        "description": "Pairwise LS mean differences between group levels",
        "cardinality": "per_contrast",
        "dimensions": [
          "fixed_effect"
        ],
        "statistics": [
          "estimate",
          "SE",
          "CI_lower",
          "CI_upper",
          "t_statistic",
          "p_value",
          "df"
        ]
      },
      {
        "class": "covariance_parameters",
        "description": "Residual variance estimate",
        "cardinality": "singleton",
        "dimensions": null,
        "statistics": [
          "estimate"
        ]
      }
    ]
  },
  "assumptions": [
    "Independence of observations",
    "Normality of residuals",
    "Homogeneity of regression slopes (if no covariate:fixed_effect interaction)",
    "Linear relationship between covariate and response"
  ],
  "input_roles": [
    {
      "name": "response",
      "statisticalRole": "response",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The response/dependent variable"
    },
    {
      "name": "covariate",
      "statisticalRole": "covariate",
      "dataType": "decimal",
      "required": false,
      "cardinality": "multiple",
      "description": "Continuous covariate(s) for adjustment (e.g., baseline value, age)"
    },
    {
      "name": "fixed_effect",
      "statisticalRole": "fixed_effect",
      "dataType": "code",
      "required": true,
      "cardinality": "single_or_multiple",
      "description": "Grouping/factor variable(s) (e.g., treatment arm, region)"
    }
  ]
}
