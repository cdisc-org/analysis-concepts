{
  "$schema": "../../../model/json_schema/acdc_method.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "conceptId": "M.CumulativeCount",
  "name": "Cumulative Count",
  "label": "Cumulative Count",
  "ncitCode": null,
  "description": "Computes cumulative counts across ordered categories",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := CUMCOUNT(value) OVER (group)",
    "generic_expression": "result := CUMCOUNT(<value>) OVER (<group>*)"
  },
  "inputs": [
    {
      "name": "value",
      "dataType": "code",
      "required": true,
      "cardinality": "single",
      "description": "The categorical variable to summarize"
    },
    {
      "name": "group",
      "dataType": "code",
      "required": false,
      "cardinality": "multiple",
      "description": "Optional grouping variable(s)"
    }
  ],
  "outputs": [
    {
      "output_type": "computed_value",
      "name": "result",
      "indexed_by": [
        "group"
      ],
      "unit_policy": "dimensionless",
      "dataType": "integer"
    }
  ]
}
