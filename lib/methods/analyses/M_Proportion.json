{
  "$schema": "../../../model/json_schema/acdc_method.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "conceptId": "M.Proportion",
  "name": "Proportion",
  "label": "Proportion",
  "ncitCode": null,
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO_0000607",
      "display": "proportion"
    }
  ],
  "description": "Computes the proportion and percentage per category of a categorical variable",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := PROP(value) OVER (group)",
    "generic_expression": "result := PROP(<value>) OVER (<group>*)"
  },
  "configurations": [
    {
      "name": "ci_method",
      "dataType": "enum",
      "defaultValue": "exact_clopper_pearson",
      "enumValues": [
        "exact_clopper_pearson",
        "wilson",
        "wald",
        "agresti_coull",
        "jeffreys"
      ],
      "description": "Method for confidence interval calculation"
    },
    {
      "name": "ci_level",
      "dataType": "decimal",
      "defaultValue": 0.95,
      "description": "Confidence level"
    }
  ],
  "inputs": [
    {
      "name": "value",
      "dataType": "code",
      "required": true,
      "cardinality": "single",
      "description": "The categorical variable to summarize"
    },
    {
      "name": "group",
      "dataType": "code",
      "required": false,
      "cardinality": "multiple",
      "description": "Optional grouping variable(s)"
    }
  ],
  "outputs": [
    {
      "output_type": "computed_value",
      "name": "result",
      "indexed_by": [
        "group"
      ],
      "unit_policy": "dimensionless",
      "dataType": "decimal"
    }
  ]
}
