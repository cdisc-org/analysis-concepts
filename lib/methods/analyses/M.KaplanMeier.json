{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.6.0",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "oid": "M.KaplanMeier",
  "name": "Kaplan-Meier Estimator",
  "type": "analysis",
  "class": "Survival Models",
  "intent": [
    "TimeToEventEstimate"
  ],
  "description": "Non-parametric survival function estimation with optional grouping",
  "formula": {
    "notation": "survival",
    "default_expression": "Surv(time, event) ~ fixed_effect",
    "generic_expression": "Surv(<time>, <event>) ~ <fixed_effect>?",
    "notes": "If no group is specified, estimates a single survival curve. With a group variable, produces stratified curves."
  },
  "configurations": [
    {
      "name": "conf_type",
      "dataType": "enum",
      "defaultValue": "log-log",
      "enumValues": [
        "log-log",
        "log",
        "plain",
        "arcsin"
      ],
      "description": "Confidence interval transformation type"
    }
  ],
  "output_specification": {
    "output_classes": [
      {
        "class": "event_summary",
        "description": "Summary of events and censoring per group",
        "cardinality": "per_group",
        "dimensions": [
          "fixed_effect"
        ],
        "statistics": [
          "n_risk",
          "n_event",
          "n_censored"
        ]
      },
      {
        "class": "survival_table",
        "description": "Life table with survival estimates at each event time",
        "cardinality": "per_event_time",
        "dimensions": [
          "fixed_effect",
          "time"
        ],
        "statistics": [
          "n_risk",
          "n_event",
          "n_censored",
          "survival_prob",
          "SE",
          "CI_lower",
          "CI_upper"
        ]
      },
      {
        "class": "median_survival",
        "description": "Median survival time per group with confidence interval",
        "cardinality": "per_group",
        "dimensions": [
          "fixed_effect"
        ],
        "statistics": [
          "median",
          "CI_lower",
          "CI_upper"
        ]
      },
      {
        "class": "landmark_estimates",
        "description": "Survival probability at specific landmark times",
        "cardinality": "per_group_per_landmark",
        "dimensions": [
          "fixed_effect",
          "time"
        ],
        "statistics": [
          "survival_prob",
          "SE",
          "CI_lower",
          "CI_upper"
        ]
      }
    ]
  },
  "assumptions": [
    "Non-informative censoring",
    "Independence of survival times"
  ],
  "input_roles": [
    {
      "name": "time",
      "statisticalRole": "response",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "Time to event or censoring"
    },
    {
      "name": "event",
      "statisticalRole": "response",
      "dataType": "boolean",
      "required": true,
      "cardinality": "single",
      "description": "Event indicator (1=event, 0=censored)"
    },
    {
      "name": "fixed_effect",
      "statisticalRole": "fixed_effect",
      "dataType": "code",
      "required": false,
      "cardinality": "single",
      "description": "Optional grouping variable for stratified curves"
    }
  ]
}
