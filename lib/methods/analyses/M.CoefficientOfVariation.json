{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.8.0",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "oid": "M.CoefficientOfVariation",
  "name": "Coefficient of Variation",
  "type": "analysis",
  "class": "Dispersion",
  "intent": [
    "DescriptiveSummary"
  ],
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO_0000236",
      "display": "coefficient of variation"
    }
  ],
  "description": "Computes the coefficient of variation (SD/mean × 100) of a numeric variable",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := CV(response) OVER (group)",
    "generic_expression": "result := CV(<response>) OVER (<group>*)"
  },
  "configurations": [],
  "output_specification": {
    "output_classes": [
      {
        "class": "computed_value",
        "description": "The computed statistic per group",
        "dimensions": [
          "group"
        ],
        "statistics": [
          "cv"
        ]
      }
    ]
  },
  "assumptions": [],
  "input_roles": [
    {
      "name": "response",
      "statisticalRole": "response",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The variable to summarize"
    },
    {
      "name": "group",
      "statisticalRole": "fixed_effect",
      "dataType": "code",
      "required": false,
      "cardinality": "single_or_multiple",
      "description": "Optional grouping variable(s)"
    }
  ]
}
