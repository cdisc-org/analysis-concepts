{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.5.0",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "oid": "M.CMH",
  "name": "Cochran-Mantel-Haenszel Test",
  "type": "analysis",
  "class": "Categorical Data Analysis",
  "intent": [
    "CategoricalAssociation"
  ],
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO_0000149",
      "display": "Cochran-Mantel-Haenszel test"
    }
  ],
  "stato_r_implementation": "xtabs(formula = ~., data = parent.frame(), subset, sparse = FALSE,\n      na.action, exclude = c(NA, NaN), drop.unused.levels = FALSE)\n\nhttp://stat.ethz.ch/R-manual/R-patched/library/stats/html/xtabs.html\n\nflat contingency tables:\n\nftable(x, ...)\n\nhttp://stat.ethz.ch/R-manual/R-patched/library/stats/html/ftable.html",
  "description": "Stratified analysis for 2x2xK tables controlling for strata. Tests the null hypothesis of no association between response and group after adjusting for strata.",
  "formula": {
    "notation": "wilkinson_rogers",
    "default_expression": "response ~ group | strata",
    "generic_expression": "<response> ~ <fixed_effect> | <strata>+",
    "notes": "The '|' denotes stratification. Multiple strata variables produce cross-classified strata."
  },
  "configurations": [
    {
      "name": "or_type",
      "dataType": "enum",
      "defaultValue": "common",
      "enumValues": [
        "common",
        "stratum_specific"
      ],
      "description": "Odds ratio reporting type"
    }
  ],
  "output_specification": {
    "output_classes": [
      {
        "class": "test_result",
        "description": "CMH test of conditional independence",
        "cardinality": "singleton",
        "indexed_by": null,
        "statistics": [
          "chi_squared",
          "p_value",
          "df"
        ]
      },
      {
        "class": "association_measures",
        "description": "Common (Mantel-Haenszel) odds ratio across strata",
        "cardinality": "singleton",
        "indexed_by": null,
        "statistics": [
          "odds_ratio",
          "CI_lower",
          "CI_upper"
        ],
        "sub_types": [
          {
            "name": "common_odds_ratio",
            "indexed_by": null,
            "description": "Pooled MH odds ratio",
            "statistics": [
              "odds_ratio",
              "CI_lower",
              "CI_upper"
            ]
          },
          {
            "name": "stratum_specific_odds_ratios",
            "indexed_by": [
              "stratum"
            ],
            "description": "Odds ratio within each stratum",
            "statistics": [
              "odds_ratio",
              "CI_lower",
              "CI_upper"
            ]
          }
        ]
      },
      {
        "class": "homogeneity_test",
        "description": "Breslow-Day test for homogeneity of odds ratios across strata",
        "cardinality": "singleton",
        "indexed_by": null,
        "statistics": [
          "chi_squared",
          "p_value",
          "df"
        ]
      }
    ]
  },
  "assumptions": [
    "Independence within strata",
    "Homogeneous odds ratios across strata (for common OR interpretation)"
  ],
  "input_roles": [
    {
      "name": "response",
      "statisticalRole": "response",
      "dataType": "string",
      "required": true,
      "cardinality": "single",
      "description": "Binary response variable"
    },
    {
      "name": "group",
      "statisticalRole": "fixed_effect",
      "dataType": "string",
      "required": true,
      "cardinality": "single",
      "description": "Treatment group (binary)"
    },
    {
      "name": "strata",
      "statisticalRole": "strata",
      "dataType": "string",
      "required": true,
      "cardinality": "single_or_multiple",
      "description": "Stratification variable(s)"
    }
  ]
}
