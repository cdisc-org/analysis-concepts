{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.5.0",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "oid": "M.CumulativeFrequency",
  "name": "Cumulative Frequency",
  "type": "analysis",
  "class": "Counting",
  "intent": ["DescriptiveSummary"],
  "codings": [],
  "description": "Computes cumulative frequency and percentage across ordered categories",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := CUMFREQ(category) OVER (group)",
    "generic_expression": "result := CUMFREQ(<category>) OVER (<group>*)"
  },
  "configurations": [],
  "output_specification": {
    "output_classes": [
      {
        "class": "computed_value",
        "description": "The cumulative frequency and percentage per category per group",
        "cardinality": "per_group",
        "indexed_by": ["group"],
        "statistics": ["cumulative_n", "cumulative_pct"]
      }
    ]
  },
  "assumptions": [],
  "input_roles": [
    {
      "name": "category",
      "statisticalRole": "response",
      "dataType": "string",
      "required": true,
      "cardinality": "single",
      "description": "The categorical variable to summarize"
    },
    {
      "name": "group",
      "statisticalRole": "fixed_effect",
      "dataType": "string",
      "required": false,
      "cardinality": "single_or_multiple",
      "description": "Optional grouping variable(s)"
    }
  ]
}
