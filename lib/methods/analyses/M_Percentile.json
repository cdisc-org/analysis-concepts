{
  "$schema": "../../../model/json_schema/acdc_method.schema.json",
  "schema_version": "0.9.1",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "conceptId": "M.Percentile",
  "name": "Percentile",
  "label": "Percentile",
  "ncitCode": null,
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO_0000293",
      "display": "percentile"
    }
  ],
  "description": "Computes the value at a specified percentile rank",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := PERCENTILE(value, percentile_value) OVER (group)",
    "generic_expression": "result := PERCENTILE(<value>, <percentile_value>) OVER (<group>*)"
  },
  "configurations": [
    {
      "name": "percentile_value",
      "dataType": "decimal",
      "defaultValue": 50,
      "description": "Percentile rank (0 to 100)"
    },
    {
      "name": "percentile_method",
      "dataType": "enum",
      "defaultValue": "type_2",
      "enumValues": [
        "type_2",
        "type_6",
        "type_7"
      ],
      "description": "Interpolation method (type_2 = SAS default, type_7 = R default)"
    }
  ],
  "inputs": [
    {
      "name": "value",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The variable to summarize"
    },
    {
      "name": "group",
      "dataType": "code",
      "required": false,
      "cardinality": "multiple",
      "description": "Optional grouping variable(s)"
    }
  ],
  "outputs": [
    {
      "output_type": "computed_value",
      "name": "result",
      "indexed_by": [
        "group"
      ],
      "unit_policy": "preserved",
      "dataType": "decimal"
    }
  ]
}
