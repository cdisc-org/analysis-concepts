{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.8.0",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "oid": "M.CumulativeCount",
  "name": "Cumulative Count",
  "type": "analysis",
  "class": "Counting",
  "intent": [
    "DescriptiveSummary"
  ],
  "codings": [],
  "description": "Computes cumulative counts across ordered categories",
  "formula": {
    "notation": "assignment",
    "default_expression": "result := CUMCOUNT(response) OVER (group)",
    "generic_expression": "result := CUMCOUNT(<response>) OVER (<group>*)"
  },
  "configurations": [],
  "output_specification": {
    "output_classes": [
      {
        "class": "computed_value",
        "description": "The cumulative count and percentage per category per group",
        "dimensions": [
          "group"
        ],
        "statistics": [
          "cumulative_n",
          "cumulative_pct"
        ]
      }
    ]
  },
  "assumptions": [],
  "input_roles": [
    {
      "name": "response",
      "statisticalRole": "response",
      "dataType": "code",
      "required": true,
      "cardinality": "single",
      "description": "The categorical variable to summarize"
    },
    {
      "name": "group",
      "statisticalRole": "fixed_effect",
      "dataType": "code",
      "required": false,
      "cardinality": "single_or_multiple",
      "description": "Optional grouping variable(s)"
    }
  ]
}
