{
  "$schema": "../../model/method/acdc_methods.schema.json",
  "schema_version": "0.6.0",
  "$vocabulary": {
    "statistics": "../../model/method/statistics_vocabulary.json",
    "output_classes": "../../model/method/output_class_templates.json",
    "formula_grammar": "../../model/method/formula_grammar.json"
  },
  "oid": "M.ANOVA",
  "name": "ANOVA",
  "type": "analysis",
  "class": "General Linear Models",
  "intent": [
    "GroupComparison"
  ],
  "codings": [
    {
      "system": "http://purl.obolibrary.org/obo/stato",
      "code": "STATO_0000048",
      "display": "ANOVA"
    }
  ],
  "description": "Analysis of Variance - compares means across multiple groups",
  "formula": {
    "notation": "wilkinson_rogers",
    "default_expression": "response ~ fixed_effect",
    "generic_expression": "<response> ~ <fixed_effect>+ + (<fixed_effect>:<fixed_effect>)*",
    "notes": "One or more factors; interactions can be added with ':' or '*' operator"
  },
  "configurations": [
    {
      "name": "ss_type",
      "dataType": "enum",
      "defaultValue": "III",
      "enumValues": [
        "I",
        "II",
        "III",
        "IV"
      ],
      "description": "Sum of squares type"
    }
  ],
  "output_specification": {
    "output_classes": [
      {
        "class": "fit_statistics",
        "template_ref": "fit_statistics",
        "statistics": [
          "R_squared",
          "AIC"
        ],
        "indexed_by": null
      },
      {
        "class": "type3_tests",
        "description": "ANOVA table: one row per model term",
        "cardinality": "per_term",
        "indexed_by": [
          "fixed_effect",
          "fixed_effect:fixed_effect"
        ],
        "statistics": [
          "SS",
          "df",
          "MS",
          "F_statistic",
          "p_value"
        ]
      },
      {
        "class": "ls_means",
        "description": "Marginal means per factor level",
        "cardinality": "per_level",
        "indexed_by": [
          "fixed_effect"
        ],
        "statistics": [
          "estimate",
          "SE",
          "CI_lower",
          "CI_upper",
          "df"
        ]
      },
      {
        "class": "contrasts",
        "description": "Pairwise differences between group means",
        "cardinality": "per_contrast",
        "indexed_by": [
          "fixed_effect"
        ],
        "statistics": [
          "estimate",
          "SE",
          "CI_lower",
          "CI_upper",
          "t_statistic",
          "p_value",
          "df"
        ]
      }
    ]
  },
  "assumptions": [
    "Independence of observations",
    "Normality within groups",
    "Homogeneity of variance"
  ],
  "input_roles": [
    {
      "name": "response",
      "statisticalRole": "response",
      "dataType": "decimal",
      "required": true,
      "cardinality": "single",
      "description": "The response variable"
    },
    {
      "name": "fixed_effect",
      "statisticalRole": "fixed_effect",
      "dataType": "code",
      "required": true,
      "cardinality": "single_or_multiple",
      "description": "Grouping/factor variable(s)"
    }
  ]
}
