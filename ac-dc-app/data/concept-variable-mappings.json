{
  "sdtm": {
    "_meta": {
      "standard": "SDTM",
      "modelVersion": "v2.0",
      "igVersion": "v3.4",
      "sources": ["SDTM_v2.0.csv", "SDTMIG_v3.4.csv"]
    },
    "classVariables": {
      "GeneralObservations": {
        "identifiers": [
          { "name": "STUDYID", "label": "Study Identifier", "type": "Char", "role": "Identifier" },
          { "name": "DOMAIN", "label": "Domain Abbreviation", "type": "Char", "role": "Identifier" },
          { "name": "USUBJID", "label": "Unique Subject Identifier", "type": "Char", "role": "Identifier" },
          { "name": "--SEQ", "label": "Sequence Number", "type": "Num", "role": "Identifier" },
          { "name": "--GRPID", "label": "Group ID", "type": "Char", "role": "Identifier" },
          { "name": "--REFID", "label": "Reference ID", "type": "Char", "role": "Identifier" },
          { "name": "--SPID", "label": "Sponsor-Defined Identifier", "type": "Char", "role": "Identifier" },
          { "name": "--LNKID", "label": "Link ID", "type": "Char", "role": "Identifier" }
        ],
        "timing": [
          { "name": "VISITNUM", "label": "Visit Number", "type": "Num", "role": "Timing" },
          { "name": "VISIT", "label": "Visit Name", "type": "Char", "role": "Timing" },
          { "name": "VISITDY", "label": "Planned Study Day of Visit", "type": "Num", "role": "Timing" },
          { "name": "EPOCH", "label": "Epoch", "type": "Char", "role": "Timing" },
          { "name": "--DTC", "label": "Date/Time of Collection", "type": "Char", "role": "Timing" },
          { "name": "--STDTC", "label": "Start Date/Time of Observation", "type": "Char", "role": "Timing" },
          { "name": "--ENDTC", "label": "End Date/Time of Observation", "type": "Char", "role": "Timing" },
          { "name": "--DY", "label": "Study Day of Visit/Collection/Exam", "type": "Num", "role": "Timing" }
        ]
      },
      "Findings": {
        "topic": [
          { "name": "--TESTCD", "label": "Short Name of Measurement, Test, or Exam", "type": "Char", "role": "Topic" },
          { "name": "--TEST", "label": "Name of Measurement, Test, or Exam", "type": "Char", "role": "Synonym Qualifier" }
        ],
        "qualifiers": [
          { "name": "--CAT", "label": "Category", "type": "Char", "role": "Grouping Qualifier" },
          { "name": "--SCAT", "label": "Subcategory", "type": "Char", "role": "Grouping Qualifier" },
          { "name": "--POS", "label": "Position of Subject", "type": "Char", "role": "Record Qualifier" },
          { "name": "--LOC", "label": "Location", "type": "Char", "role": "Record Qualifier" },
          { "name": "--LAT", "label": "Laterality", "type": "Char", "role": "Variable Qualifier" },
          { "name": "--METHOD", "label": "Method", "type": "Char", "role": "Record Qualifier" },
          { "name": "--SPEC", "label": "Specimen Type", "type": "Char", "role": "Record Qualifier" },
          { "name": "--STAT", "label": "Completion Status", "type": "Char", "role": "Record Qualifier" }
        ],
        "results": [
          { "name": "--ORRES", "label": "Result or Finding in Original Units", "type": "Char", "role": "Result Qualifier" },
          { "name": "--ORRESU", "label": "Original Units", "type": "Char", "role": "Variable Qualifier" },
          { "name": "--ORNRLO", "label": "Normal Range Lower Limit-Original Units", "type": "Char", "role": "Variable Qualifier" },
          { "name": "--ORNRHI", "label": "Normal Range Upper Limit-Original Units", "type": "Char", "role": "Variable Qualifier" },
          { "name": "--STRESC", "label": "Result or Finding in Std Format", "type": "Char", "role": "Result Qualifier" },
          { "name": "--STRESN", "label": "Numeric Result/Finding in Std Units", "type": "Num", "role": "Result Qualifier" },
          { "name": "--STRESU", "label": "Standard Units", "type": "Char", "role": "Variable Qualifier" },
          { "name": "--STNRLO", "label": "Normal Range Lower Limit-Std Units", "type": "Num", "role": "Variable Qualifier" },
          { "name": "--STNRHI", "label": "Normal Range Upper Limit-Std Units", "type": "Num", "role": "Variable Qualifier" },
          { "name": "--NRIND", "label": "Normal/Abnormal/Reference Range Indicator", "type": "Char", "role": "Variable Qualifier" }
        ]
      },
      "Events": {
        "topic": [
          { "name": "--TERM", "label": "Reported Term", "type": "Char", "role": "Topic" },
          { "name": "--MODIFY", "label": "Modified Reported Term", "type": "Char", "role": "Synonym Qualifier" },
          { "name": "--DECOD", "label": "Dictionary-Derived Term", "type": "Char", "role": "Synonym Qualifier" }
        ],
        "qualifiers": [
          { "name": "--BODSYS", "label": "Body System or Organ Class", "type": "Char", "role": "Record Qualifier" },
          { "name": "--SEV", "label": "Severity/Intensity", "type": "Char", "role": "Record Qualifier" },
          { "name": "--SER", "label": "Serious Event", "type": "Char", "role": "Record Qualifier" },
          { "name": "--ACN", "label": "Action Taken with Study Treatment", "type": "Char", "role": "Record Qualifier" },
          { "name": "--REL", "label": "Causality", "type": "Char", "role": "Record Qualifier" },
          { "name": "--OUT", "label": "Outcome of Adverse Event", "type": "Char", "role": "Record Qualifier" },
          { "name": "--CAT", "label": "Category", "type": "Char", "role": "Grouping Qualifier" },
          { "name": "--SCAT", "label": "Subcategory", "type": "Char", "role": "Grouping Qualifier" },
          { "name": "--LOC", "label": "Location of Event", "type": "Char", "role": "Record Qualifier" },
          { "name": "--LAT", "label": "Laterality", "type": "Char", "role": "Variable Qualifier" }
        ]
      },
      "Interventions": {
        "topic": [
          { "name": "--TRT", "label": "Name of Treatment", "type": "Char", "role": "Topic" },
          { "name": "--MODIFY", "label": "Modified Treatment Name", "type": "Char", "role": "Synonym Qualifier" },
          { "name": "--DECOD", "label": "Standardized Treatment Name", "type": "Char", "role": "Synonym Qualifier" }
        ],
        "qualifiers": [
          { "name": "--CAT", "label": "Category", "type": "Char", "role": "Grouping Qualifier" },
          { "name": "--SCAT", "label": "Subcategory", "type": "Char", "role": "Grouping Qualifier" },
          { "name": "--DOSE", "label": "Dose", "type": "Num", "role": "Record Qualifier" },
          { "name": "--DOSU", "label": "Dose Units", "type": "Char", "role": "Variable Qualifier" },
          { "name": "--DOSFRM", "label": "Dose Form", "type": "Char", "role": "Variable Qualifier" },
          { "name": "--DOSFRQ", "label": "Dosing Frequency", "type": "Char", "role": "Record Qualifier" },
          { "name": "--ROUTE", "label": "Route of Administration", "type": "Char", "role": "Record Qualifier" },
          { "name": "--INDC", "label": "Indication", "type": "Char", "role": "Record Qualifier" },
          { "name": "--CLAS", "label": "Class", "type": "Char", "role": "Variable Qualifier" },
          { "name": "--LOC", "label": "Location of Administration", "type": "Char", "role": "Record Qualifier" }
        ]
      }
    },
    "concepts": {
      "Observation": {
        "variable": "--ORRES",
        "facets": {
          "Identification.Topic": "--TESTCD",
          "Result.Value": "--ORRES",
          "Result.Unit": "--ORRESU",
          "Timing.CollectionDateTime": "--DTC"
        },
        "byDataType": {
          "decimal": "--ORRES",
          "code": "--ORRESU",
          "string": "--ORRES"
        },
        "notes": "SDTM raw observation (Findings class). --ORRES is the original result as collected (may have mixed units across rows); --ORRESU the original unit. Used as INPUT by T.UnitConversion. The -- prefix is a placeholder substituted with the domain code (VS/LB/EG/etc.)."
      },
      "Measure": {
        "variable": "--STRESN/--STRESC",
        "facets": {
          "Result.Value": "--STRESN",
          "Result.Unit": "--STRESU"
        },
        "byDataType": {
          "decimal": "--STRESN",
          "code": "--STRESC",
          "string": "--STRESC"
        },
        "notes": "SDTM standardized result (Findings class). --STRESN holds the unit-converted numeric value; --STRESU the standardized unit code. Natural OUTPUT for T.UnitConversion."
      },
      "EventTerm": {
        "variable": "--TERM/--DECOD",
        "facets": {
          "Identification.Topic": "--TERM",
          "Coding.PreferredTerm": "--DECOD",
          "Coding.BodySystem": "--BODSYS",
          "Coding.HighLevelTerm": "--HLT",
          "Coding.HighLevelGroupTerm": "--HLGT",
          "Coding.LowLevelTerm": "--LLT",
          "Severity": "--SEV",
          "Seriousness": "--SER",
          "ActionTaken": "--ACN",
          "Causality": "--REL",
          "Outcome": "--OUT"
        },
        "byDataType": {
          "string": "--TERM",
          "code": "--DECOD"
        },
        "notes": "SDTM event observation (Events class). --TERM is the reported/verbatim term (Topic); --DECOD is the dictionary-derived preferred term. MedDRA hierarchy facets provide multi-level coding. The -- prefix is substituted with domain code (AE/MH/CE/etc.)."
      },
      "Intervention": {
        "variable": "--TRT/--DECOD",
        "facets": {
          "Identification.Topic": "--TRT",
          "Coding.StandardizedName": "--DECOD",
          "Coding.Class": "--CLAS",
          "Coding.ClassCode": "--CLASCD",
          "Dosing.Dose": "--DOSE",
          "Dosing.Unit": "--DOSU",
          "Dosing.Form": "--DOSFRM",
          "Dosing.Frequency": "--DOSFRQ",
          "Dosing.Route": "--ROUTE",
          "Indication": "--INDC"
        },
        "byDataType": {
          "string": "--TRT",
          "code": "--DECOD",
          "decimal": "--DOSE"
        },
        "notes": "SDTM intervention record (Interventions class). --TRT is the reported treatment name (Topic); --DECOD is the standardized/coded name. The -- prefix is substituted with domain code (CM/EX/EC/SU/etc.)."
      }
    },
    "dimensions": {
      "Subject": {
        "variable": "USUBJID",
        "byDataType": {
          "id": "USUBJID",
          "string": "USUBJID"
        },
        "notes": "Unique subject identifier (shared with ADaM — same concept, same variable name)"
      },
      "Parameter": {
        "variable": "--TESTCD/--TEST",
        "byDataType": {
          "code": "--TESTCD",
          "string": "--TEST"
        },
        "notes": "Test code and label. Domain-prefixed (VSTESTCD/VSTEST for VS, LBTESTCD/LBTEST for LB, etc.)"
      },
      "Timing": {
        "variable": "--DTC",
        "byDataType": {
          "date": "--DTC",
          "dateTime": "--DTC",
          "string": "--DTC"
        },
        "notes": "Collection date/time (VSDTC, LBDTC, etc.)"
      },
      "Visit": {
        "variable": "VISIT/VISITNUM",
        "byDataType": {
          "code": "VISIT",
          "string": "VISIT",
          "integer": "VISITNUM",
          "decimal": "VISITNUM"
        },
        "notes": "Protocol-defined visit (raw SDTM visit, not analysis visit)"
      },
      "Study": {
        "variable": "STUDYID",
        "byDataType": {
          "id": "STUDYID",
          "string": "STUDYID"
        }
      },
      "Site": {
        "variable": "SITEID",
        "byDataType": {
          "id": "SITEID",
          "string": "SITEID"
        }
      },
      "Treatment": {
        "variable": "ARM/ACTARM",
        "byDataType": {
          "code": "ARMCD",
          "string": "ARM"
        },
        "intentType": {
          "Planned": { "code": "ARMCD", "string": "ARM" },
          "Actual": { "code": "ACTARMCD", "string": "ACTARM" }
        },
        "notes": "Treatment arm from DM domain. Not domain-prefixed. IntentType qualifier selects Planned (ARM) vs Actual (ACTARM)."
      },
      "Category": {
        "variable": "--CAT/--SCAT",
        "byDataType": {
          "code": "--CAT",
          "string": "--CAT"
        },
        "notes": "Category grouping variable. --CAT is the primary category. Present in Events, Findings, and Interventions classes. Domain-prefixed."
      },
      "Subcategory": {
        "variable": "--SCAT",
        "byDataType": {
          "code": "--SCAT",
          "string": "--SCAT"
        },
        "notes": "Subcategory within --CAT. Present in Events, Findings, and Interventions classes. Domain-prefixed."
      },
      "Epoch": {
        "variable": "EPOCH",
        "byDataType": {
          "code": "EPOCH",
          "string": "EPOCH"
        },
        "notes": "Trial epoch (e.g., SCREENING, TREATMENT, FOLLOW-UP). A Timing variable from General Observations, not domain-prefixed."
      },
      "Location": {
        "variable": "--LOC",
        "byDataType": {
          "string": "--LOC",
          "code": "--LOC"
        },
        "notes": "Anatomical location of finding/event/intervention. Domain-prefixed."
      },
      "Laterality": {
        "variable": "--LAT",
        "byDataType": {
          "code": "--LAT",
          "string": "--LAT"
        },
        "notes": "Laterality qualifier for anatomical location (RIGHT, LEFT, BILATERAL). Domain-prefixed."
      },
      "Specimen": {
        "variable": "--SPEC",
        "byDataType": {
          "code": "--SPEC",
          "string": "--SPEC"
        },
        "notes": "Specimen type for laboratory/findings observations. Domain-prefixed (e.g., LBSPEC)."
      },
      "Method": {
        "variable": "--METHOD",
        "byDataType": {
          "code": "--METHOD",
          "string": "--METHOD"
        },
        "notes": "Method of test or examination. Domain-prefixed (e.g., VSMETHOD, EGMETHOD)."
      },
      "Position": {
        "variable": "--POS",
        "byDataType": {
          "code": "--POS",
          "string": "--POS"
        },
        "notes": "Position of subject during observation (e.g., STANDING, SITTING, SUPINE). Domain-prefixed."
      }
    }
  },
