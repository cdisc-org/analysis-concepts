{
  "sdtm": {
    "concepts": {
      "Observation": {
        "variable": "--ORRES",
        "facets": {
          "Identification.Topic": "--TESTCD",
          "Result.Value": "--ORRES",
          "Result.Unit": "--ORRESU",
          "Timing.CollectionDateTime": "--DTC"
        },
        "byDataType": {
          "decimal": "--ORRES",
          "code": "--ORRESU",
          "string": "--ORRES"
        },
        "notes": "SDTM raw observation. --ORRES is the original result as collected (may have mixed units across rows); --ORRESU the original unit. Used as INPUT by T.UnitConversion. The -- prefix is a placeholder substituted with the domain code (VS/LB/EG/etc.) from the BC's dataset specialization at resolution time (matching the xxxFL pattern in adam.concepts.Flag)."
      },
      "Measure": {
        "variable": "--STRESN/--STRESC",
        "facets": {
          "Result.Value": "--STRESN",
          "Result.Unit": "--STRESU"
        },
        "byDataType": {
          "decimal": "--STRESN",
          "code": "--STRESC",
          "string": "--STRESC"
        },
        "notes": "SDTM standardized result. --STRESN holds the unit-converted numeric value; --STRESU the standardized unit code. These are the natural OUTPUT destinations for T.UnitConversion and any other derivation that populates SDTM standardized variables. When the same derived Measure is also presented in an ADaM view, the adam.concepts.Measure facets map it to AVAL/AVALU."
      }
    },
    "dimensions": {
      "Subject": {
        "variable": "USUBJID",
        "byDataType": {
          "id": "USUBJID",
          "string": "USUBJID"
        },
        "notes": "Unique subject identifier (shared with ADaM — same concept, same variable name)"
      },
      "Parameter": {
        "variable": "--TESTCD/--TEST",
        "byDataType": {
          "code": "--TESTCD",
          "string": "--TEST"
        },
        "notes": "Test code and label. Domain-prefixed (VSTESTCD/VSTEST for VS, LBTESTCD/LBTEST for LB, etc.)"
      },
      "Timing": {
        "variable": "--DTC",
        "byDataType": {
          "date": "--DTC",
          "dateTime": "--DTC",
          "string": "--DTC"
        },
        "notes": "Collection date/time (VSDTC, LBDTC, etc.)"
      },
      "Visit": {
        "variable": "VISIT/VISITNUM",
        "byDataType": {
          "code": "VISIT",
          "string": "VISIT",
          "integer": "VISITNUM",
          "decimal": "VISITNUM"
        },
        "notes": "Protocol-defined visit (raw SDTM visit, not analysis visit)"
      },
      "Study": {
        "variable": "STUDYID",
        "byDataType": {
          "id": "STUDYID",
          "string": "STUDYID"
        }
      },
      "Site": {
        "variable": "SITEID",
        "byDataType": {
          "id": "SITEID",
          "string": "SITEID"
        }
      },
      "Treatment": {
        "variable": "ARM/ACTARM",
        "byDataType": {
          "code": "ARMCD",
          "string": "ARM"
        },
        "intentType": {
          "Planned": { "code": "ARMCD", "string": "ARM" },
          "Actual": { "code": "ACTARMCD", "string": "ACTARM" }
        },
        "notes": "Treatment arm from DM domain. Not domain-prefixed. IntentType qualifier selects Planned (ARM) vs Actual (ACTARM)."
      }
    }
  },
  "adam": {
    "concepts": {
      "Measure": {
        "variable": "AVAL/AVALC/BASE",
        "byDataType": {
          "decimal": "AVAL",
          "baseline": "BASE",
          "code": "AVALC",
          "string": "AVALC"
        },
        "facets": {
          "Result.Value": "AVAL",
          "Result.Unit": "AVALU"
        },
        "notes": "Analysis value (numeric or character). BASE is the baseline value. Facets map the Measure concept's structural parts (Result.Value, Result.Unit) to the corresponding ADaM variables — used by the load/present grammar when a binding declares qualifierType='facet' (e.g., T.UnitConversion outputs Measure.Result.Value → AVAL, Measure.Result.Unit → AVALU)."
      },
      "Change": {
        "variable": "CHG",
        "byDataType": {
          "decimal": "CHG"
        },
        "notes": "Change from baseline"
      },
