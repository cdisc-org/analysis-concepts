        },
        "notes": "Percent change from baseline"
      },
      "Shift": {
        "variable": "AVALC",
        "byDataType": {
          "code": "AVALC",
          "string": "AVALC"
        },
        "notes": "Shift category (character)"
      },
      "PeakValue": {
        "variable": "AVAL",
        "byDataType": {
          "decimal": "AVAL"
        },
        "notes": "Peak/extreme analysis value"
      },
