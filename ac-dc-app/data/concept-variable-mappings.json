          "string": "AVALC"
        },
        "facets": {
          "Result.Value": "AVAL",
          "Result.Unit": "AVALU"
        },
        "notes": "Analysis value (numeric or character). BASE is the baseline value. Facets map the Measure concept's structural parts (Result.Value, Result.Unit) to the corresponding ADaM variables."
      },
      "Change": {
        "variable": "CHG",
        "byDataType": {
          "decimal": "CHG"
        },
