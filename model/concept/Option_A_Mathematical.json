{
  "model": "DC",
  "version": "0.20a",
  "variant": "mathematical",
  "description": "Derivation Concepts with mathematical naming. Each concept describes what kind of data the result is. The concept carries only its result structure (value type and unit behaviour). Identification (MeasureIdentifier, MeasureCategory, Sequence) and shared dimensions (Subject, Timing, etc.) are external — selected by the Transformation.",
  "sharedDimensions": {
    "note": "Dimensional concepts — also part of the concept model, but not derivation concepts. They define the context in which a derivation is performed. The Transformation selects which ones apply. The Implementation maps them to physical columns (e.g. USUBJID → Subject, PARAMCD → Parameter, AVISIT → Visit).",
    "Subject": {
      "cardinality": "1"
    },
    "Timing": {
      "cardinality": "1"
    },
    "Parameter": {
      "cardinality": "0..1"
    },
    "AnalysisVisit": {
      "cardinality": "0..1"
    },
    "Treatment": {
      "cardinality": "0..1"
    },
    "Population": {
      "cardinality": "0..1"
    },
    "Period": {
      "cardinality": "0..1"
    }
  },
  "categories": {
    "PointComputation": {
      "definition": "A value computed at a specific point, without reference comparison, temporal aggregation, event aggregation, or classification.",
      "inputPattern": "Method-driven. The concept defines output shape only; the method determines what inputs are needed.",
      "concepts": {
        "DirectValue": {
          "definition": "A derived value produced by applying a method to one or more source observations or derived measures.",
          "math": "f(x₁, …, xₙ)",
          "examples": [
            "BMI",
            "eGFR",
            "QTcF",
            "unit-converted lab",
            "LOCF imputed value",
            "questionnaire total score"
          ],
          "result": {
            "valueType": [
              "NumericValue",
              "CharacterValue",
              "CodedResponse"
            ],
            "unit": "inherited or specified"
          }
        }
      }
    },
    "Comparison": {
      "definition": "Data expressing the relationship between two values of the same parameter.",
      "inputPattern": "Concept-driven. Requires 2× DirectValue inputs, intrinsic to the category.",
      "concepts": {
        "AbsoluteDifference": {
          "definition": "Arithmetic difference between two values of the same parameter.",
          "math": "x − x_ref",
          "examples": [
            "change from baseline in SBP",
            "inter-visit difference in weight",
            "difference between duplicate measurements"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        },
        "RelativeDifference": {
          "definition": "Proportional difference between two values of the same parameter, relative to the reference.",
          "math": "(x − x_ref) / x_ref",
          "examples": [
            "percent change from baseline in tumor size",
            "relative change in eGFR"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "fixed: %"
          }
        },
        "Ratio": {
          "definition": "Quotient of two values of the same parameter.",
          "math": "x / x_ref",
          "examples": [
            "fold change in biomarker",
            "post/pre treatment ratio"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "dimensionless"
          }
        },
        "LogRatio": {
          "definition": "Logarithm of the quotient of two values. Symmetric, additive scale.",
          "math": "ln(x / x_ref)",
          "examples": [
            "log-fold change in gene expression",
            "log-ratio of drug concentrations"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "dimensionless"
          }
        },
        "CategoricalTransition": {
          "definition": "Categorical movement between two values of the same parameter.",
          "math": "class(x) vs class(x_ref)",
          "examples": [
            "normal-to-abnormal shift in lab",
            "severity worsening from baseline"
          ],
          "result": {
            "valueType": "CodedResponse",
            "unit": "none"
          }
        }
      }
    },
    "SequenceAggregate": {
      "definition": "A summary of an ordered series of the same parameter over time.",
      "inputPattern": "Concept-driven. Requires 1× DirectValue input; the ordered series emerges from dimensional scoping.",
      "concepts": {
        "SequenceMaximum": {
          "definition": "Maximum value in an ordered sequence.",
          "math": "sup{yᵢ}",
          "examples": [
            "Cmax",
            "maximum heart rate during exercise",
            "highest recorded SBP"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        },
        "SequenceMinimum": {
          "definition": "Minimum value in an ordered sequence.",
          "math": "inf{yᵢ}",
          "examples": [
            "Ctrough",
            "nadir neutrophil count",
            "minimum platelet count"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        },
        "SequenceArgMaximum": {
          "definition": "Time at which maximum value occurs.",
          "math": "argmax_t{yᵢ}",
          "examples": [
            "Tmax"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        },
        "SequenceArgMinimum": {
          "definition": "Time at which minimum value occurs.",
          "math": "argmin_t{yᵢ}",
          "examples": [
            "time to nadir"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        },
        "SequenceIntegral": {
          "definition": "Integrated value over time (area under curve).",
          "math": "∫y dt",
          "examples": [
            "AUC₀₋₂₄",
            "AUC₀₋∞",
            "glucose AUC during OGTT"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "source_unit × time_unit"
          }
        },
        "SequenceCumulativeSum": {
          "definition": "Running total over time.",
          "math": "Σyᵢ for i ≤ k",
          "examples": [
            "cumulative dose",
            "cumulative exposure"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        },
        "SequenceRateOfChange": {
          "definition": "Rate of change over a segment (slope).",
          "math": "Δy/Δt",
          "examples": [
            "eGFR slope",
            "tumor growth rate",
            "rate of decline in FEV1"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "source_unit / time_unit"
          }
        },
        "ExponentialDecayConstant": {
          "definition": "Time for value to decline by 50%.",
          "math": "ln(2) / λ",
          "examples": [
            "drug half-life",
            "antibody half-life"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        },
        "SequenceTerminalValue": {
          "definition": "Last observed value in the sequence.",
          "math": "yₙ",
          "examples": [
            "last observed concentration",
            "end-of-study value"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        },
        "SequenceInitialValue": {
          "definition": "First value in the sequence.",
          "math": "y₁",
          "examples": [
            "first post-dose concentration",
            "initial measurement"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        },
        "SequenceThresholdDuration": {
          "definition": "Total time spent above or below a threshold.",
          "math": "measure({t : y(t) > θ})",
          "examples": [
            "time in therapeutic range",
            "time above MIC",
            "time in hypoglycemia"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        },
        "SequenceThresholdCrossing": {
          "definition": "Time at which sequence first crosses a threshold.",
          "math": "inf{t : y(t) = θ}",
          "examples": [
            "time to target concentration",
            "time to normalization"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        },
        "SequenceRange": {
          "definition": "Difference between maximum and minimum in sequence.",
          "math": "sup{yᵢ} − inf{yᵢ}",
          "examples": [
            "blood pressure variability",
            "PK concentration range"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        }
      }
    },
    "EventAggregate": {
      "definition": "A summary of discrete event occurrences on a timeline.",
      "inputPattern": "Concept-driven. Requires 1× Observation (OC layer); the event set emerges from dimensional scoping.",
      "concepts": {
        "Count": {
          "definition": "Number of occurrences of an event or condition.",
          "math": "|{events}|",
          "examples": [
            "number of AEs",
            "seizure count",
            "number of exacerbations"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "none"
          }
        },
        "Rate": {
          "definition": "Number of occurrences per unit of time or exposure.",
          "math": "|{events}| / T",
          "examples": [
            "annualized relapse rate",
            "AE rate per patient-year"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "events / time_unit"
          }
        },
        "TimeToEvent": {
          "definition": "Duration from a defined start to event occurrence or censoring.",
          "math": "inf{tᵢ}",
          "examples": [
            "time to first AE",
            "overall survival",
            "progression-free survival"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        },
        "InterEventInterval": {
          "definition": "Duration between consecutive recurrent events.",
          "math": "t_{i+1} − tᵢ",
          "examples": [
            "time between seizures",
            "inter-exacerbation interval"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        }
      }
    },
    "Classification": {
      "definition": "A derivation mapping value(s) to a categorical assignment.",
      "inputPattern": "Concept-driven. Requires 1× any concept as input (the value being classified).",
      "concepts": {
        "Indicator": {
          "definition": "Binary indicator evaluating a criterion (Y/N).",
          "math": "I(criterion)",
          "examples": [
            "baseline flag (ABLFL)",
            "population flag (SAFFL)",
            "responder flag"
          ],
          "result": {
            "valueType": "CodedResponse",
            "unit": "none"
          }
        },
        "Classification": {
          "definition": "Derived categorical grouping from rules.",
          "math": "f(x) → {c₁, c₂, …}",
          "examples": [
            "severity grade",
            "BMI category",
            "renal impairment stage"
          ],
          "result": {
            "valueType": "CodedResponse",
            "unit": "none"
          }
        },
        "Rank": {
          "definition": "Ordinal position of value within a defined scope.",
          "math": "rank(x) within group",
          "examples": [
            "worst post-baseline rank",
            "severity ranking"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "none"
          }
        },
        "Quantile": {
          "definition": "Distributional bin assignment (tertiles, quartiles, quintiles).",
          "math": "Qₖ where F(x) in bin k",
          "examples": [
            "exposure quartile",
            "baseline severity tertile"
          ],
          "result": {
            "valueType": "CodedResponse",
            "unit": "none"
          }
        }
      }
    }
  }
}