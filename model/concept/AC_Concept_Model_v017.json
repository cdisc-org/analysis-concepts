  "categories": {
    "note": "Level 3 AC Categories. Group result patterns that typically appear together.",
    "TreatmentComparison": {
      "definition": "A comparison of an outcome between treatment groups, producing estimated treatment effects with inference.",
      "typicallyInvolves": [
        "Contrasts",
        "LSMeans",
        "Type3Tests",
        "ParameterEstimates",
        "FitStatistics"
      ],
      "typicalMethods": [
