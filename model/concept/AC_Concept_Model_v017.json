{
  "model": "AC",
  "version": "0.17",
  "description": "Analysis Concept model with three levels: Statistical Concepts (atoms), Result Patterns (molecules), and Categories (groupings). The shared statistics vocabulary is referenced by both methods and result patterns but owned by neither. — v0.17 corrects four result patterns (LSMeans, Contrasts, ComputedValue, CovarianceParameters) whose dimensions previously held layer-3 study values; they now match the layer-1 abstract pattern shape from output_class_templates.json.",
  "$vocabulary": {
    "valueTypes": "../shared/fhir_value_types.json"
  },
  "designPrinciples": [
    "Statistical concepts are individual data points — each has its own identity in the graph",
    "Result patterns group statistical concepts that belong together and should be interpreted together",
    "Categories group result patterns that typically appear together in the same kind of analysis",
    "The shared statistics vocabulary is independent — methods reference it for output slots, result patterns reference it for grouping",
    "Methods do not reference AC concepts — the Transformation maps method output slots to result patterns",
    "The model is representation-neutral — it works in tabular, graph, or any other physical format"
  ],
  "qualifierTypes": {
    "note": "Qualifier types are defined in the CDDM shared vocabulary (CDDM_Shared_QualifierTypes.json). They represent semantically different versions of a data definition. Statistical concepts and result patterns do not have qualifiers — qualifiers apply only to data definitions at the transformation/CDDM layer.",
    "$ref": "CDDM_Shared_QualifierTypes.json"
  },
