      ],
      "code": {
        "system": "NCI",
        "value": null
      }
    },
    "DescriptiveSummary": {
      "definition": "A statistical summary of a distribution within a group. No comparison between groups required. After the FHIR-datatype retargeting pass, descriptive methods produce FHIR Quantity (or Count/Duration) atomic values directly rather than structured ResultPatterns; typicallyInvolves is empty because the per-row output isn't a multi-statistic table.",
      "typicallyInvolves": [],
      "typicalMethods": [
        "M.Mean",
        "M.Quartile",
        "M.Skewness",
        "M.Sum",
        "M.WinsorizedMean"
      ],
