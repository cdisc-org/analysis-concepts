        "M.ANCOVA",
        "M.TTest",
        "M.WilcoxonRankSum"
      ],
      "code": {
        "system": "NCI",
        "value": null
      }
    },
    "SurvivalAnalysis": {
      "definition": "An analysis of time-to-event outcomes, estimating survival patterns and comparing them between groups.",
      "typicallyInvolves": [
        "TestResult",
        "SurvivalTable",
        "MedianSurvival",
        "EventSummary",
        "HazardRatioEstimates"
