{
  "model": "DC",
  "version": "0.20b",
  "variant": "clinical",
  "description": "Derivation Concepts with clinical naming. Each concept describes what kind of data the result is, using names a clinical programmer would naturally use. The concept carries only its result structure (value type and unit behaviour). Identification (MeasureIdentifier, MeasureCategory, Sequence) and shared dimensions (Subject, Timing, etc.) are external — selected by the Transformation.",
  "namingPrinciples": [
    "Would a clinical programmer call this data by this name without further context?",
    "Does the name describe what the data IS, not how or why it was produced?",
    "Can you say the name without referencing a parameter, visit, or standard?",
    "Would you handle this data differently than any other concept?",
    "Could you define it in one sentence without referencing another concept?",
    "Is it a different ingredient type, not a different brand of the same ingredient?"
  ],
  "sharedDimensions": {
    "note": "Dimensional concepts — also part of the concept model, but not derivation concepts. They define the context in which a derivation is performed. The Transformation selects which ones apply. The Implementation maps them to physical columns (e.g. USUBJID → Subject, PARAMCD → Parameter, AVISIT → Visit).",
    "Subject": {
      "cardinality": "1"
    },
    "Timing": {
      "cardinality": "1"
    },
    "Parameter": {
      "cardinality": "0..1"
    },
    "AnalysisVisit": {
      "cardinality": "0..1"
    },
    "Treatment": {
      "cardinality": "0..1"
    },
    "Population": {
      "cardinality": "0..1"
    },
    "Period": {
      "cardinality": "0..1"
    }
  },
  "categories": {
    "PointComputation": {
      "definition": "A value computed at a specific point, without reference comparison, temporal aggregation, event aggregation, or classification.",
      "inputPattern": "Method-driven. The concept defines output shape only; the method determines what inputs are needed.",
      "concepts": {
        "Measure": {
          "mathematicalEquivalent": "DirectValue",
          "definition": "A value produced by applying a computation to one or more source values.",
          "math": "f(x₁, …, xₙ)",
          "examples": [
            "BMI",
            "eGFR",
            "QTcF",
            "unit-converted lab",
            "LOCF imputed value",
            "questionnaire total score"
          ],
          "result": {
            "valueType": [
              "NumericValue",
              "CharacterValue",
              "CodedResponse"
            ],
            "unit": "inherited or specified"
          }
        }
      }
    },
    "Comparison": {
      "definition": "Data expressing the relationship between two values of the same parameter.",
      "inputPattern": "Concept-driven. Requires 2× Measure inputs, intrinsic to the category.",
      "concepts": {
        "Change": {
          "mathematicalEquivalent": "AbsoluteDifference",
          "definition": "The arithmetic difference between two values of the same parameter.",
          "math": "x − x_ref",
          "examples": [
            "change from baseline in SBP",
            "inter-visit difference in weight",
            "difference between duplicate measurements"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        },
        "PercentChange": {
          "mathematicalEquivalent": "RelativeDifference",
          "definition": "The proportional difference between two values of the same parameter, expressed as a percentage.",
          "math": "(x − x_ref) / x_ref",
          "examples": [
            "percent change from baseline in tumor size",
            "relative change in eGFR"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "fixed: %"
          }
        },
        "Ratio": {
          "mathematicalEquivalent": "Ratio",
          "definition": "The quotient of two values of the same parameter.",
          "math": "x / x_ref",
          "examples": [
            "fold change in biomarker",
            "post/pre treatment ratio"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "dimensionless"
          }
        },
        "LogRatio": {
          "mathematicalEquivalent": "LogRatio",
          "definition": "The logarithm of the quotient of two values. Symmetric, additive scale.",
          "math": "ln(x / x_ref)",
          "examples": [
            "log-fold change in gene expression",
            "log-ratio of drug concentrations"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "dimensionless"
          }
        },
        "Shift": {
          "mathematicalEquivalent": "CategoricalTransition",
          "definition": "The categorical movement between two values of the same parameter.",
          "math": "class(x) vs class(x_ref)",
          "examples": [
            "normal-to-abnormal shift in lab",
            "severity worsening from baseline"
          ],
          "result": {
            "valueType": "CodedResponse",
            "unit": "none"
          }
        }
      }
    },
    "SequenceAggregate": {
      "definition": "A summary of an ordered series of the same parameter over time.",
      "inputPattern": "Concept-driven. Requires 1× Measure input; the ordered series emerges from dimensional scoping.",
      "concepts": {
        "PeakValue": {
          "mathematicalEquivalent": "SequenceMaximum",
          "definition": "The highest value in an ordered series.",
          "math": "sup{yᵢ}",
          "examples": [
            "Cmax",
            "maximum heart rate during exercise",
            "highest recorded SBP"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        },
        "TroughValue": {
          "mathematicalEquivalent": "SequenceMinimum",
          "definition": "The lowest value in an ordered series.",
          "math": "inf{yᵢ}",
          "examples": [
            "Ctrough",
            "nadir neutrophil count",
            "minimum platelet count"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        },
        "TimeToPeak": {
          "mathematicalEquivalent": "SequenceArgMaximum",
          "definition": "The time at which the highest value occurs.",
          "math": "argmax_t{yᵢ}",
          "examples": [
            "Tmax"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        },
        "TimeToTrough": {
          "mathematicalEquivalent": "SequenceArgMinimum",
          "definition": "The time at which the lowest value occurs.",
          "math": "argmin_t{yᵢ}",
          "examples": [
            "time to nadir"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        },
        "AreaUnderCurve": {
          "mathematicalEquivalent": "SequenceIntegral",
          "definition": "The integrated value over time.",
          "math": "∫y dt",
          "examples": [
            "AUC₀₋₂₄",
            "AUC₀₋∞",
            "glucose AUC during OGTT"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "source_unit × time_unit"
          }
        },
        "CumulativeTotal": {
          "mathematicalEquivalent": "SequenceCumulativeSum",
          "definition": "The running total accumulated over time.",
          "math": "Σyᵢ for i ≤ k",
          "examples": [
            "cumulative dose",
            "cumulative exposure"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        },
        "RateOfChange": {
          "mathematicalEquivalent": "SequenceRateOfChange",
          "definition": "The rate at which a value changes over a time segment.",
          "math": "Δy/Δt",
          "examples": [
            "eGFR slope",
            "tumor growth rate",
            "rate of decline in FEV1"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "source_unit / time_unit"
          }
        },
        "HalfLife": {
          "mathematicalEquivalent": "ExponentialDecayConstant",
          "definition": "The time for a value to decline by half.",
          "math": "ln(2) / λ",
          "examples": [
            "drug half-life",
            "antibody half-life"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        },
        "LastValue": {
          "mathematicalEquivalent": "SequenceTerminalValue",
          "definition": "The last observed value in an ordered series.",
          "math": "yₙ",
          "examples": [
            "last observed concentration",
            "end-of-study value"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        },
        "FirstValue": {
          "mathematicalEquivalent": "SequenceInitialValue",
          "definition": "The first value in an ordered series.",
          "math": "y₁",
          "examples": [
            "first post-dose concentration",
            "initial measurement"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        },
        "TimeInState": {
          "mathematicalEquivalent": "SequenceThresholdDuration",
          "definition": "The total time spent above or below a threshold.",
          "math": "measure({t : y(t) > θ})",
          "examples": [
            "time in therapeutic range",
            "time above MIC",
            "time in hypoglycemia"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        },
        "TimeToThreshold": {
          "mathematicalEquivalent": "SequenceThresholdCrossing",
          "definition": "The time at which a series first crosses a defined threshold.",
          "math": "inf{t : y(t) = θ}",
          "examples": [
            "time to target concentration",
            "time to normalization"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        },
        "Range": {
          "mathematicalEquivalent": "SequenceRange",
          "definition": "The difference between the highest and lowest values in a series.",
          "math": "sup{yᵢ} − inf{yᵢ}",
          "examples": [
            "blood pressure variability",
            "PK concentration range"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "inherited"
          }
        }
      }
    },
    "EventAggregate": {
      "definition": "A summary of discrete event occurrences on a timeline.",
      "inputPattern": "Concept-driven. Requires 1× Observation (OC layer); the event set emerges from dimensional scoping.",
      "concepts": {
        "EventCount": {
          "mathematicalEquivalent": "Count",
          "definition": "The number of times an event or condition occurs.",
          "math": "|{events}|",
          "examples": [
            "number of AEs",
            "seizure count",
            "number of exacerbations"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "none"
          }
        },
        "EventRate": {
          "mathematicalEquivalent": "Rate",
          "definition": "The number of occurrences per unit of time or exposure.",
          "math": "|{events}| / T",
          "examples": [
            "annualized relapse rate",
            "AE rate per patient-year"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "events / time_unit"
          }
        },
        "TimeToEvent": {
          "mathematicalEquivalent": "TimeToEvent",
          "definition": "The duration from a defined start to event occurrence or censoring.",
          "math": "inf{tᵢ}",
          "examples": [
            "time to first AE",
            "overall survival",
            "progression-free survival"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        },
        "TimeBetweenEvents": {
          "mathematicalEquivalent": "InterEventInterval",
          "definition": "The duration between consecutive recurrent events.",
          "math": "t_{i+1} − tᵢ",
          "examples": [
            "time between seizures",
            "inter-exacerbation interval"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "time unit"
          }
        }
      }
    },
    "Classification": {
      "definition": "A derivation mapping value(s) to a categorical assignment.",
      "inputPattern": "Concept-driven. Requires 1× any concept as input (the value being classified).",
      "concepts": {
        "Flag": {
          "mathematicalEquivalent": "Indicator",
          "definition": "A binary indicator evaluating a criterion (Y/N).",
          "math": "I(criterion)",
          "examples": [
            "baseline flag (ABLFL)",
            "population flag (SAFFL)",
            "responder flag"
          ],
          "result": {
            "valueType": "CodedResponse",
            "unit": "none"
          }
        },
        "Category": {
          "mathematicalEquivalent": "Classification",
          "definition": "A categorical grouping derived from rules.",
          "math": "f(x) → {c₁, c₂, …}",
          "examples": [
            "severity grade",
            "BMI category",
            "renal impairment stage"
          ],
          "result": {
            "valueType": "CodedResponse",
            "unit": "none"
          }
        },
        "Rank": {
          "mathematicalEquivalent": "Rank",
          "definition": "The ordinal position of a value within a defined scope.",
          "math": "rank(x) within group",
          "examples": [
            "worst post-baseline rank",
            "severity ranking"
          ],
          "result": {
            "valueType": "NumericValue",
            "unit": "none"
          }
        },
        "QuantileGroup": {
          "mathematicalEquivalent": "Quantile",
          "definition": "A distributional bin assignment (tertiles, quartiles, quintiles).",
          "math": "Qₖ where F(x) in bin k",
          "examples": [
            "exposure quartile",
            "baseline severity tertile"
          ],
          "result": {
            "valueType": "CodedResponse",
            "unit": "none"
          }
        }
      }
    }
  }
}