dpref=unlist(nci_service_get_concept_preferred_name_from_term(bc_1$element_key[d]))}
else {dpref='NA'}
keys<-list('conceptId','href','shortName','dataType','exampleSet')
if (bc_1$element_value[d]==''){
vals<-list(dc,
paste0('https://ncithesaurus.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&ns=ncit&code=',dc),
dpref,
'NA',
'NA')
}
else {
vals<-list(dc,
paste0('https://ncithesaurus.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&ns=ncit&code=',dc),
dpref,
'NA',
bc_1$element_value[d])
}
data_element<-data.frame(setNames(as.list(vals), keys))
data_elements<-rbind(data_elements,data_element)
}
bc_keys<-c("packageDate",
"packageType",
"conceptId",
"href",
"parentConceptId",
"category",
"shortName",
'synonym',
'resultScale',
'definition',
"dataElementConcepts")
bc_value<-c('2023-04-25',
'bc',
unlist(nci_service_get_concept_code_from_term(id)),
paste0('https://ncithesaurus.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&ns=ncit&code=',nci_service_get_concept_code_from_term(id)),
unlist(get_parent_concept_code(nci_service_get_concept_code_from_term(id))),
df_1$CAT,
df_1$TEST,
'',
'',
unlist(get_nci_concept_definition(nci_service_get_concept_code_from_term(id))),
as.yaml(data_elements, column.major = FALSE))
print(bc_keys)
print(bc_value)
bc_list<- as.yaml(setNames(as.list(bc_value), bc_keys))
assign(paste0('bc_',id) , bc_list)
write_yaml(bc_list, paste0('/Users/kwl/Documents/CDISC/CDISC Pilot Study/bc_yaml/bc_',id,'.yaml'))
}
}
