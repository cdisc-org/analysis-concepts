{
  "version": "0.4.0",
  "description": "BNF grammar for method expressions. Analysis methods use Wilkinson-Rogers style; derivations use assignment style.",
  "bnf": [
    "<method_expression>   ::= <analysis_formula> | <derivation_formula>",
    "",
    "<analysis_formula>    ::= <lhs> '~' <rhs>",
    "                        | <lhs> '~' <rhs> '|' <repeated_spec>",
    "",
    "<lhs>                 ::= <response_term>",
    "                        | 'Surv(' <variable> ',' <variable> ')'",
    "                        | 'cbind(' <variable_list> ')'",
    "",
    "<rhs>                 ::= <term>",
    "                        | <rhs> '+' <term>",
    "",
    "<term>                ::= <main_effect>",
    "                        | <interaction>",
    "                        | <expansion>",
    "",
    "<main_effect>         ::= <variable>",
    "",
    "<interaction>         ::= <variable> ':' <variable>",
    "                        | <variable> ':' <variable> ':' <variable>",
    "",
    "<expansion>           ::= <variable> '*' <variable>",
    "                        (* A*B expands to A + B + A:B *)",
    "",
    "<repeated_spec>       ::= <subject_var>",
    "                        | <subject_var> '/' <repeated_var>",
    "",
    "<variable_list>       ::= <variable>",
    "                        | <variable_list> ',' <variable>",
    "",
    "<variable>            ::= <identifier>",
    "                        | <identifier> '[' <role_tag> ']'",
    "",
    "<role_tag>            ::= 'response' | 'covariate' | 'fixed_effect'",
    "                        | 'repeated_factor' | 'repeated_subject'",
    "                        | 'strata' | 'offset'",
    "",
    "<derivation_formula>  ::= <output_var> ':=' <expression>",
    "",
    "<expression>          ::= <operand>",
    "                        | <expression> <arith_op> <expression>",
    "                        | <function_call>",
    "                        | <conditional>",
    "",
    "<function_call>       ::= <func_name> '(' <arg_list> ')'",
    "                        | <func_name> '(' <expression> ')' 'OVER' <partition>",
    "",
    "<conditional>         ::= 'IF(' <predicate> ',' <expression> ',' <expression> ')'",
    "                        | 'CASE' <when_clause>+ 'END'",
    "                        | 'COALESCE(' <arg_list> ')'",
    "",
    "<arith_op>            ::= '+' | '-' | '*' | '/'",
    "",
    "<partition>           ::= <variable_list>"
  ],
  "cardinality_notation": {
    "<role>": "exactly one instance required",
    "<role>+": "one or more instances",
    "<role>*": "zero or more instances",
    "<role>?": "zero or one instance (optional)"
  }
}
